    print("║    Android Remote Access with Screen Stream   ║")
    print("╚════════════════════════════════════════════════╝")
    print(f"\033[0m")
    print(f"Listening on {LISTENER_IP}:{LISTENER_PORT}")
    print("Waiting for connections...\n")
    
    while True:
        conn, addr = server.accept()
        client = RemoteClient(conn, addr)
        thread = threading.Thread(target=client.handle)
        thread.daemon = True
        thread.start()

if __name__ == "__main__":
