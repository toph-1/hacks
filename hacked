    echo "2. Click 'Create App'"
    echo "3. Choose 'Website to APK'"
    echo "4. Upload the HTML file from your Desktop"
    echo "5. Click 'Generate APK'"
    echo ""
    echo -e "${YELLOW}The APK will download to your computer${NC}"
    echo ""
    read -p "Press Enter to continue..."
}

# =============================================
# METHOD 3: TERMUX SCRIPT (RUNS ON PHONE)
# =============================================

method_termux() {
    clear
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     METHOD 3: Termux Script           ║${NC}"
    echo -e "${BLUE}║     Runs directly on phone            ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
    echo ""
    
    # Get local IP
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    
    # Create Termux script on Desktop
    cat > "$DESKTOP/termux_remote.sh" << EOF
#!/data/data/com.termux/files/usr/bin/bash

# Termux Remote Control Script
echo "================================="
echo "Termux Remote Control"
echo "================================="
echo ""

# Install required packages
echo "Installing packages..."
pkg update -y
pkg install -y termux-api termux-tools

# Get device info
echo ""
echo "Device Information:"
echo "  Model: \$(getprop ro.product.model)"
echo "  Android: \$(getprop ro.build.version.release)"
echo "  Battery: \$(termux-battery-status | grep percentage)"
echo ""

# Connect to computer
echo "Connecting to $LOCAL_IP..."
echo ""
echo "Commands:"
echo "  info  - Show device info"
echo "  photo - Take photo"
echo "  files - List files"
echo "  exit  - Disconnect"
echo ""

while true; do
    read -p "> " cmd
    case \$cmd in
        info)
            echo "Model: \$(getprop ro.product.model)"
            echo "Android: \$(getprop ro.build.version.release)"
            ;;
        photo)
            echo "Taking photo..."
            termux-camera-photo /sdcard/photo.jpg
            echo "Photo saved to /sdcard/photo.jpg"
            ;;
        files)
            ls -la /sdcard
            ;;
        exit)
            break
            ;;
        *)
            echo "Unknown command"
            ;;
    esac
done
EOF

    chmod +x "$DESKTOP/termux_remote.sh"
    
    # Create instructions
    cat > "$DESKTOP/termux_instructions.txt" << EOF
=== TERMUX SETUP ===

1. Install Termux from F-Droid (not Play Store)
   https://f-droid.org/en/packages/com.termux/

2. Open Termux and run:
   termux-setup-storage
   pkg update
   pkg install python

3. Copy termux_remote.sh to your phone:
   - Use USB cable to copy to Download folder
   - Or use: python3 -m http.server 8000 (on computer)
   - Then on phone: wget http://$LOCAL_IP:8000/termux_remote.sh

4. In Termux, run:
   chmod +x termux_remote.sh
   ./termux_remote.sh

That's it! The script will run on your phone.
EOF

    echo -e "${GREEN}✓ Termux script created on Desktop: termux_remote.sh${NC}"
    echo -e "${GREEN}✓ Instructions: termux_instructions.txt${NC}"
    echo ""
    read -p "Press Enter to continue..."
}

# =============================================
# METHOD 4: DROIDSCRIPT APK (EASY APK BUILDING)
# =============================================

method_droidscript() {
    clear
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     METHOD 4: DroidScript APK         ║${NC}"
    echo -e "${BLUE}║     Builds APK directly on phone      ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
    echo ""
    
    # Get local IP
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    
    # Create DroidScript code
    cat > "$DESKTOP/droidscript.js" << EOF
// DroidScript Remote Control App
// Copy this code into DroidScript

var ip = "$LOCAL_IP";
var port = 8080;

function OnStart() {
    // Create layout
    var lay = app.CreateLayout("linear", "FillXY");
    lay.SetBackground("#2196F3");
    
    // Title
    var title = app.CreateText("Remote Control");
    title.SetTextSize(32);
    title.SetTextColor("#FFFFFF");
    title.SetMargins(0, 50, 0, 0);
    lay.AddChild(title);
    
    // IP Display
    var ipText = app.CreateText(ip + ":" + port);
    ipText.SetTextSize(20);
    ipText.SetTextColor("#FFFFFF");
    ipText.SetMargins(0, 20, 0, 50);
    lay.AddChild(ipText);
    
    // Info Button
    var btnInfo = app.CreateButton("Get Phone Info", 0.6, 0.1);
    btnInfo.SetTextColor("#2196F3");
    btnInfo.SetBackground("#FFFFFF");
    btnInfo.SetOnClick(btnInfo_OnClick);
    lay.AddChild(btnInfo);
    
    // Photo Button
    var btnPhoto = app.CreateButton("Take Photo", 0.6, 0.1);
    btnPhoto.SetTextColor("#2196F3");
    btnPhoto.SetBackground("#FFFFFF");
    btnPhoto.SetMargins(0, 20, 0, 0);
    btnPhoto.SetOnClick(btnPhoto_OnClick);
    lay.AddChild(btnPhoto);
    
    // Files Button
    var btnFiles = app.CreateButton("List Files", 0.6, 0.1);
    btnFiles.SetTextColor("#2196F3");
    btnFiles.SetBackground("#FFFFFF");
    btnFiles.SetMargins(0, 20, 0, 0);
    btnFiles.SetOnClick(btnFiles_OnClick);
    lay.AddChild(btnFiles);
    
    // Status Text
    var status = app.CreateText("Ready");
    status.SetTextSize(16);
    status.SetTextColor("#FFFFFF");
    status.SetMargins(0, 50, 0, 0);
    lay.AddChild(status);
    
    app.AddLayout(lay);
    
    function btnInfo_OnClick() {
        status.SetText("Getting info...");
        var info = "Model: " + app.GetDeviceInfo() + "\\n";
        info += "Android: " + app.GetOSVersion();
        app.Alert(info);
        status.SetText("Info retrieved");
    }
    
    function btnPhoto_OnClick() {
        status.SetText("Taking photo...");
        app.TakePicture("/sdcard/photo.jpg");
        status.SetText("Photo saved");
    }
    
    function btnFiles_OnClick() {
        status.SetText("Listing files...");
        app.ListFiles("/sdcard");
        status.SetText("Files listed");
    }
}
EOF

    echo -e "${GREEN}✓ DroidScript code created on Desktop: droidscript.js${NC}"
    echo ""
    echo -e "${YELLOW}To build APK:${NC}"
    echo "1. Install DroidScript from Play Store"
    echo "2. Open DroidScript on your phone"
    echo "3. Create new project"
    echo "4. Replace the code with the contents of droidscript.js"
    echo "5. Click 'Build APK'"
    echo ""
    echo -e "${GREEN}The APK will be built directly on your phone!${NC}"
    echo ""
    read -p "Press Enter to continue..."
}

# =============================================
# SHOW FILES ON DESKTOP
# =============================================

show_files() {
    clear
    echo -e "${BLUE}=== FILES ON DESKTOP ===${NC}\n"
    
    if [ -d "$DESKTOP" ]; then
        ls -la "$DESKTOP" | grep -E "\.(html|sh|js|txt|apk)" || echo "No remote control files found"
    else
        echo "Desktop folder not found"
    fi
    
    echo ""
    read -p "Press Enter to continue..."
}

