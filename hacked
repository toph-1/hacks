# =============================================
# METHOD 4: CREATE SIMPLE PYTHON SERVER
# =============================================

create_python_server() {
    clear
    echo -e "${BLUE}=== CREATING PYTHON SERVER FOR APK ===${NC}\n"
    
    cat > "$DESKTOP/server.py" << EOF
#!/usr/bin/env python3
"""
Simple server for Android Remote Access
Run this on your computer to receive connections
"""

import socket
import threading
import time
from datetime import datetime

HOST = '0.0.0.0'
PORT = $LISTENER_PORT

def handle_client(conn, addr):
    print(f"\n[+] Connection from {addr}")
    
    while True:
        try:
            data = conn.recv(1024)
            if not data:
                break
            
            message = data.decode().strip()
            print(f"[{addr[0]}] {message}")
            
            # Send response
            response = f"OK at {datetime.now()}"
            conn.send(response.encode())
            
        except Exception as e:
            print(f"Error: {e}")
            break
    
    conn.close()
    print(f"[-] Disconnected from {addr}")

def main():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((HOST, PORT))
    server.listen(5)
    
    print(f"\n{'='*50}")
    print(f"ANDROID REMOTE ACCESS SERVER")
    print(f"{'='*50}")
    print(f"Server IP: {HOST}")
    print(f"Server Port: {PORT}")
    print(f"Your computer IP: {get_local_ip()}")
    print(f"{'='*50}\n")
    
    while True:
        conn, addr = server.accept()
        thread = threading.Thread(target=handle_client, args=(conn, addr))
        thread.daemon = True
        thread.start()

def get_local_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except:
        return "127.0.0.1"

if __name__ == "__main__":
    main()
EOF

    chmod +x "$DESKTOP/server.py"
    
    echo -e "${GREEN}✓ Python server created on Desktop: server.py${NC}"
    echo ""
    echo -e "${YELLOW}To run the server:${NC}"
    echo "  python3 $DESKTOP/server.py"
    echo ""
    echo -e "${YELLOW}The APK you build will connect to:${NC}"
    echo "  IP: $LISTENER_IP"
    echo "  Port: $LISTENER_PORT"
}

