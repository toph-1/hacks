EOF

    # Create RemoteService.java
    cat > src/com/remote/access/RemoteService.java << EOF
package com.remote.access;

import android.app.Service;
import android.content.Intent;
import android.os.IBinder;
import android.util.Log;
import java.io.*;
import java.net.*;

public class RemoteService extends Service {
    private static final String TAG = "RemoteService";
    private Thread connectionThread;
    
    @Override
    public int onStartCommand(Intent intent, int flags, int startId) {
        String ip = intent.getStringExtra("ip");
        int port = intent.getIntExtra("port", $LISTENER_PORT);
        
        connectionThread = new Thread(() -> connectToServer(ip, port));
        connectionThread.start();
        
        return START_STICKY;
    }
    
    private void connectToServer(String ip, int port) {
        try {
            Socket socket = new Socket(ip, port);
            PrintWriter out = new PrintWriter(socket.getOutputStream(), true);
            
            out.println("Hello from Android!");
            
            // Keep connection alive
            while (true) {
                Thread.sleep(1000);
            }
            
        } catch (Exception e) {
            Log.e(TAG, "Connection error", e);
        }
    }
    
    @Override
    public IBinder onBind(Intent intent) {
        return null;
    }
}
EOF

    # Create build.xml for Ant (simplest build system)
    cat > build.xml << EOF
<?xml version="1.0" encoding="UTF-8"?>
<project name="RemoteAccess" default="help">
    <property file="local.properties" />
    <property file="ant.properties" />
    <property environment="env" />
    <condition property="sdk.dir" value="\${env.ANDROID_HOME}">
        <isset property="env.ANDROID_HOME" />
    </condition>
    <import file="\${sdk.dir}/tools/ant/build.xml" />
</project>
EOF

    # Create project.properties
    cat > project.properties << EOF
target=android-34
EOF

    echo -e "${YELLOW}Project created. Now building APK...${NC}"
    
    # Try to build with aapt directly (simplest method)
    if command -v aapt &> /dev/null; then
        # Create R.java
        mkdir -p gen
        aapt package -f -m -J gen -M AndroidManifest.xml -S res -I $ANDROID_HOME/platforms/android-34/android.jar
        
        # Compile Java
        mkdir -p bin/classes
        javac -d bin/classes -cp $ANDROID_HOME/platforms/android-34/android.jar src/com/remote/access/*.java gen/com/remote/access/R.java
        
        # Convert to dex
        dx --dex --output=bin/classes.dex bin/classes
        
        # Package APK
        aapt package -f -M AndroidManifest.xml -S res -I $ANDROID_HOME/platforms/android-34/android.jar -F bin/RemoteAccess.unaligned.apk bin/classes.dex
        
        # Align and sign
        zipalign -f 4 bin/RemoteAccess.unaligned.apk "$HOME/RemoteAccess-$LISTENER_IP.apk"
        
        echo -e "${GREEN}✓ APK built successfully!${NC}"
        echo -e "APK saved to: ${YELLOW}$HOME/RemoteAccess-$LISTENER_IP.apk${NC}"
    else
        echo -e "${RED}Could not build automatically.${NC}"
        echo -e "Creating ready-to-use Android Studio project instead..."
        
        # Create Android Studio project structure
        mkdir -p "$HOME/AndroidStudioProjects/RemoteAccess"
        cp -r * "$HOME/AndroidStudioProjects/RemoteAccess/"
        
        echo -e "${GREEN}✓ Project created at: $HOME/AndroidStudioProjects/RemoteAccess${NC}"
        echo -e "Open this folder in Android Studio and click Run"
    fi
    
    echo ""
    read -p "Press Enter to continue..."
}

