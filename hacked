#!/bin/bash

# =============================================
# Android Remote Access Control Center
# A menu-driven tool for Android remote control
# =============================================

# Configuration
CONFIG_DIR="$HOME/.android-remote"
LISTENER_IP=""
LISTENER_PORT="5555"
LOG_FILE="$CONFIG_DIR/remote.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color

# Create config directory
mkdir -p "$CONFIG_DIR"

# Function to show header
show_header() {
    clear
    echo -e "${BLUE}"
    echo "╔════════════════════════════════════════════════════════╗"
    echo "║     📱 ANDROID REMOTE ACCESS CONTROL CENTER v1.0      ║"
    echo "╚════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Function to check dependencies
check_dependencies() {
    echo -e "${YELLOW}[*] Checking dependencies...${NC}"
    
    MISSING=()
    
    # Check ADB
    if ! command -v adb &> /dev/null; then
        MISSING+=("adb")
    fi
    
    # Check scrcpy
    if ! command -v scrcpy &> /dev/null; then
        MISSING+=("scrcpy")
    fi
    
    # Check Python3
    if ! command -v python3 &> /dev/null; then
        MISSING+=("python3")
    fi
    
    # Install missing dependencies
    if [ ${#MISSING[@]} -gt 0 ]; then
        echo -e "${YELLOW}[!] Missing dependencies: ${MISSING[*]}${NC}"
        read -p "Install now? (y/n): " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            sudo apt update
            sudo apt install -y adb scrcpy python3 python3-pip
            pip3 install --user numpy opencv-python pillow
        fi
    else
        echo -e "${GREEN}[✓] All dependencies installed${NC}"
    fi
}

# Function to get/set IP
configure_ip() {
    show_header
    echo -e "${CYAN}=== NETWORK CONFIGURATION ===${NC}\n"
    
    # Get local IP
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    
    if [ -f "$CONFIG_DIR/ip.conf" ]; then
        SAVED_IP=$(cat "$CONFIG_DIR/ip.conf")
        echo -e "Your IP: ${GREEN}$LOCAL_IP${NC}"
        echo -e "Saved IP: ${YELLOW}$SAVED_IP${NC}"
        LISTENER_IP="$SAVED_IP"
    else
        echo -e "Your IP: ${GREEN}$LOCAL_IP${NC}"
        LISTENER_IP="$LOCAL_IP"
    fi
    
    echo
    echo "1) Use current IP: $LISTENER_IP"
    echo "2) Enter custom IP"
    echo "3) Back to main menu"
    echo
    read -p "Choose [1-3]: " ip_choice
    
    case $ip_choice in
        1)
            echo "$LISTENER_IP" > "$CONFIG_DIR/ip.conf"
            echo -e "${GREEN}✓ IP saved${NC}"
            ;;
        2)
            read -p "Enter IP address: " custom_ip
            if [[ $custom_ip =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
                echo "$custom_ip" > "$CONFIG_DIR/ip.conf"
                LISTENER_IP="$custom_ip"
                echo -e "${GREEN}✓ IP saved${NC}"
            else
                echo -e "${RED}Invalid IP format${NC}"
                sleep 2
            fi
            ;;
    esac
    
    # Load the IP
    if [ -f "$CONFIG_DIR/ip.conf" ]; then
        LISTENER_IP=$(cat "$CONFIG_DIR/ip.conf")
    fi
}

# Function for ADB wireless connection
menu_adb_wireless() {
    while true; do
        show_header
        echo -e "${CYAN}=== ADB WIRELESS CONNECTION ===${NC}\n"
        echo -e "Target IP: ${GREEN}$LISTENER_IP${NC}"
        echo -e "Port: ${GREEN}5555${NC}\n"
        
        echo "1) Connect via USB first (setup wireless)"
        echo "2) Connect directly to IP"
        echo "3) List connected devices"
        echo "4) Disconnect all devices"
        echo "5) Back to main menu"
        echo
        read -p "Choose [1-5]: " adb_choice
        
        case $adb_choice in
            1)
                echo -e "\n${YELLOW}[*] USB to Wireless Setup${NC}"
                echo "1. Connect phone via USB"
                echo "2. Enable USB debugging"
                read -p "Press Enter when ready..."
                
                # Check devices
                adb devices
                
                # Switch to wireless
                echo -e "\n${YELLOW}[*] Switching to wireless mode...${NC}"
                adb tcpip 5555
                
                echo -e "\n${YELLOW}[*] Now disconnect USB and press Enter${NC}"
                read -p ""
                
                # Connect wirelessly
                echo -e "\n${YELLOW}[*] Connecting to $LISTENER_IP:5555...${NC}"
                adb connect $LISTENER_IP:5555
                
                # Show result
                sleep 2
                adb devices
                
                echo -e "\n${GREEN}✓ Wireless connection setup complete${NC}"
                read -p "Press Enter to continue..."
                ;;
            2)
                echo -e "\n${YELLOW}[*] Connecting to $LISTENER_IP:5555...${NC}"
                adb connect $LISTENER_IP:5555
                sleep 2
                adb devices
                read -p "Press Enter to continue..."
                ;;
            3)
                echo -e "\n${YELLOW}[*] Connected devices:${NC}"
                adb devices
                read -p "Press Enter to continue..."
                ;;
            4)
                echo -e "\n${YELLOW}[*] Disconnecting all...${NC}"
                adb disconnect
                read -p "Press Enter to continue..."
                ;;
            5)
                return
                ;;
        esac
    done
}

# Function for screen mirroring
menu_screen_mirror() {
    while true; do
        show_header
        echo -e "${CYAN}=== SCREEN MIRRORING ===${NC}\n"
        
        echo "1) Start screen mirror (scrcpy)"
        echo "2) Start with options"
        echo "3) Record screen"
        echo "4) Take screenshot"
        echo "5) Back to main menu"
        echo
        read -p "Choose [1-5]: " screen_choice
        
        case $screen_choice in
            1)
                echo -e "\n${YELLOW}[*] Starting scrcpy...${NC}"
                echo "Press Ctrl+C to stop"
                scrcpy
                ;;
            2)
                echo -e "\n${YELLOW}Options:${NC}"
                echo "-b 2M    : Set bitrate to 2Mbps"
                echo "-f       : Fullscreen"
                echo "-r file  : Record to file"
                echo "-S       : Turn screen off"
                echo "--turn-screen-off : Turn screen off"
                echo
                read -p "Enter options: " scrcpy_opts
                scrcpy $scrcpy_opts
                ;;
            3)
                FILENAME="screen_recording_$(date +%Y%m%d_%H%M%S).mp4"
                echo -e "\n${YELLOW}[*] Recording to $FILENAME${NC}"
                echo "Press Ctrl+C to stop recording"
                scrcpy -r "$FILENAME"
                echo -e "${GREEN}✓ Recording saved to $FILENAME${NC}"
                read -p "Press Enter..."
                ;;
            4)
                FILENAME="screenshot_$(date +%Y%m%d_%H%M%S).png"
                echo -e "\n${YELLOW}[*] Taking screenshot...${NC}"
                scrcpy --window-title="Screenshot" --lock-video-orientation=0 -t
                adb exec-out screencap -p > "$FILENAME"
                echo -e "${GREEN}✓ Screenshot saved to $FILENAME${NC}"
                read -p "Press Enter..."
                ;;
            5)
                return
                ;;
        esac
    done
}

# Function for file management
menu_file_manager() {
    while true; do
        show_header
        echo -e "${CYAN}=== FILE MANAGER ===${NC}\n"
        
        echo "1) List files (current directory)"
        echo "2) Push file to device"
        echo "3) Pull file from device"
        echo "4) Install APK"
        echo "5) Browse device storage"
        echo "6) Back to main menu"
        echo
        read -p "Choose [1-6]: " file_choice
        
        case $file_choice in
            1)
                echo -e "\n${YELLOW}[*] Current directory:${NC}"
                adb shell ls -la
                read -p "Press Enter..."
                ;;
            2)
                read -p "Local file path: " local_file
                read -p "Remote path (default: /sdcard/): " remote_path
                remote_path=${remote_path:-/sdcard/}
                echo -e "\n${YELLOW}[*] Pushing file...${NC}"
                adb push "$local_file" "$remote_path"
                read -p "Press Enter..."
                ;;
            3)
                read -p "Remote file path: " remote_file
                read -p "Local destination (default: ./): " local_dest
                local_dest=${local_dest:-./}
                echo -e "\n${YELLOW}[*] Pulling file...${NC}"
                adb pull "$remote_file" "$local_dest"
                read -p "Press Enter..."
                ;;
            4)
                read -p "APK file path: " apk_file
                echo -e "\n${YELLOW}[*] Installing APK...${NC}"
                adb install "$apk_file"
                read -p "Press Enter..."
                ;;
            5)
                echo -e "\n${YELLOW}[*] Opening file browser...${NC}"
                echo "Use 'ls', 'cd', 'pull <file>', 'push <file>'"
                echo "Type 'exit' to quit"
                echo
                adb shell
                ;;
            6)
                return
                ;;
        esac
    done
}

# Function for device control
menu_device_control() {
    while true; do
        show_header
        echo -e "${CYAN}=== DEVICE CONTROL ===${NC}\n"
        
        echo "1) Open shell on device"
        echo "2) Take screenshot (save to computer)"
        echo "3) Record video"
        echo "4) Reboot device"
        echo "5) Get device info"
        echo "6) Install multiple APKs"
        echo "7) Back to main menu"
        echo
        read -p "Choose [1-7]: " control_choice
        
        case $control_choice in
            1)
                echo -e "\n${YELLOW}[*] Opening shell (type 'exit' to quit)${NC}\n"
                adb shell
                ;;
            2)
                FILENAME="screenshot_$(date +%Y%m%d_%H%M%S).png"
                echo -e "\n${YELLOW}[*] Taking screenshot...${NC}"
                adb exec-out screencap -p > "$FILENAME"
                echo -e "${GREEN}✓ Saved to $FILENAME${NC}"
                read -p "Press Enter..."
                ;;
            3)
                FILENAME="video_$(date +%Y%m%d_%H%M%S).mp4"
                echo -e "\n${YELLOW}[*] Recording video (Ctrl+C to stop)${NC}"
                echo "Press Ctrl+C when done"
                adb shell screenrecord /sdcard/$FILENAME &
                RECORD_PID=$!
                read -p "Recording... Press Enter to stop"
                kill $RECORD_PID 2>/dev/null
                adb pull /sdcard/$FILENAME
                adb shell rm /sdcard/$FILENAME
                echo -e "${GREEN}✓ Video saved to $FILENAME${NC}"
                ;;
            4)
                echo -e "\n${YELLOW}[*] Reboot options:${NC}"
                echo "1) Normal reboot"
                echo "2) Reboot to bootloader"
                echo "3) Reboot to recovery"
                read -p "Choose: " reboot_choice
                case $reboot_choice in
                    1) adb reboot ;;
                    2) adb reboot bootloader ;;
                    3) adb reboot recovery ;;
                esac
                ;;
            5)
                echo -e "\n${GREEN}Device Information:${NC}"
                echo "Model: $(adb shell getprop ro.product.model)"
                echo "Manufacturer: $(adb shell getprop ro.product.manufacturer)"
                echo "Android: $(adb shell getprop ro.build.version.release)"
                echo "SDK: $(adb shell getprop ro.build.version.sdk)"
                echo "Battery: $(adb shell dumpsys battery | grep level)"
                echo "Storage:"
                adb shell df /sdcard
                read -p "Press Enter..."
                ;;
            6)
                echo -e "\n${YELLOW}[*] Select APK files to install${NC}"
                echo "Enter APK files (space-separated) or '*' for all apks:"
                read -p "> " apk_files
                if [ "$apk_files" = "*" ]; then
                    for apk in *.apk; do
                        echo "Installing $apk..."
                        adb install "$apk"
                    done
                else
                    for apk in $apk_files; do
                        echo "Installing $apk..."
                        adb install "$apk"
                    done
                fi
                read -p "Press Enter..."
                ;;
            7)
                return
                ;;
        esac
    done
}

# Function for Python listener (custom app)
menu_python_listener() {
    while true; do
        show_header
        echo -e "${CYAN}=== CUSTOM APP LISTENER ===${NC}\n"
        
        # Check if listener script exists
        if [ ! -f "$CONFIG_DIR/listener.py" ]; then
            echo -e "${YELLOW}[*] Creating listener script...${NC}"
            cat > "$CONFIG_DIR/listener.py" << 'EOF'
#!/usr/bin/env python3
import socket
import threading
import cv2
import numpy as np
import struct
import tkinter as tk
from PIL import Image, ImageTk
import queue
import time

LISTENER_IP = "0.0.0.0"
LISTENER_PORT = 5555

class ScreenViewer:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Android Screen Viewer")
        self.root.geometry("800x600")
        self.canvas = tk.Canvas(self.root, bg='black')
        self.canvas.pack(fill=tk.BOTH, expand=True)
        self.image_queue = queue.Queue()
        self.update()
    
    def update(self):
        try:
            img = self.image_queue.get_nowait()
            if img is not None:
                window_width = self.root.winfo_width()
                window_height = self.root.winfo_height()
                if window_width > 1 and window_height > 1:
                    img_resized = cv2.resize(img, (window_width, window_height))
                    img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
                    img_pil = Image.fromarray(img_rgb)
                    img_tk = ImageTk.PhotoImage(img_pil)
                    self.canvas.delete("all")
                    self.canvas.create_image(0, 0, anchor=tk.NW, image=img_tk)
                    self.canvas.image = img_tk
        except queue.Empty:
            pass
        self.root.after(50, self.update)
    
    def show(self):
        self.root.mainloop()

class RemoteClient:
    def __init__(self, conn, addr):
        self.conn = conn
        self.addr = addr
        self.running = True
        self.streaming = False
        self.viewer = None
    
    def handle(self):
        print(f"\n[+] Connected to {self.addr}")
        threading.Thread(target=self.command_loop).start()
        
        while self.running:
            try:
                if self.streaming:
                    size_data = self.conn.recv(4)
                    if not size_data: continue
                    img_size = struct.unpack('!I', size_data)[0]
                    
                    img_data = b''
                    remaining = img_size
                    while remaining > 0:
                        chunk = self.conn.recv(min(8192, remaining))
                        img_data += chunk
                        remaining -= len(chunk)
                    
                    img = cv2.imdecode(np.frombuffer(img_data, np.uint8), cv2.IMREAD_COLOR)
                    if img is not None and self.viewer:
                        self.viewer.image_queue.put(img)
            except: break
        
        self.conn.close()
        print(f"[-] Disconnected")
    
    def command_loop(self):
        while self.running:
            try:
                cmd = input(f"\033[92m{self.addr[0]}>\033[0m ")
                if cmd == "stream":
                    self.conn.send(b"START_STREAM\n")
                    self.streaming = True
                    self.viewer = ScreenViewer()
                    threading.Thread(target=self.viewer.show).start()
                    print("[*] Streaming started")
                elif cmd == "stop":
                    self.conn.send(b"STOP_STREAM\n")
                    self.streaming = False
                    if self.viewer:
                        self.viewer.root.quit()
                    print("[*] Streaming stopped")
                elif cmd == "exit":
                    self.conn.send(b"EXIT\n")
                    self.running = False
                    break
            except: break

def start_server():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((LISTENER_IP, LISTENER_PORT))
    server.listen(5)
    print(f"\nListening on port {LISTENER_PORT}")
    print("Waiting for connections...\n")
    
    while True:
        conn, addr = server.accept()
        RemoteClient(conn, addr).handle()

if __name__ == "__main__":
    start_server()
EOF
            chmod +x "$CONFIG_DIR/listener.py"
            echo -e "${GREEN}✓ Listener created${NC}"
        fi
        
        echo "1) Start listener (port 5555)"
        echo "2) Start listener with custom port"
        echo "3) View instructions for custom app"
        echo "4) Back to main menu"
        echo
        read -p "Choose [1-4]: " listener_choice
        
        case $listener_choice in
            1)
                echo -e "\n${YELLOW}[*] Starting listener on port 5555...${NC}"
                echo "Press Ctrl+C to stop"
                cd "$CONFIG_DIR"
                python3 listener.py
                ;;
            2)
                read -p "Enter port number: " custom_port
                echo -e "\n${YELLOW}[*] Starting listener on port $custom_port...${NC}"
                sed -i "s/LISTENER_PORT = [0-9]*/LISTENER_PORT = $custom_port/" "$CONFIG_DIR/listener.py"
                echo "Press Ctrl+C to stop"
                cd "$CONFIG_DIR"
                python3 listener.py
                ;;
            3)
                echo -e "\n${GREEN}=== CUSTOM APP INSTRUCTIONS ===${NC}"
                echo ""
                echo "To create a custom Android app that connects here:"
                echo ""
                echo "1. Use MIT App Inventor (appinventor.mit.edu)"
                echo "2. Create app with Socket connection"
                echo "3. Connect to: $LISTENER_IP:5555"
                echo "4. Send commands: START_STREAM, STOP_STREAM"
                echo ""
                echo "The app should:"
                echo "- Request screen capture permission"
                echo "- Capture screen as JPEG"
                echo "- Send image size (4 bytes) then image data"
                echo ""
                read -p "Press Enter..."
                ;;
            4)
                return
                ;;
        esac
    done
}

# Main menu
main_menu() {
    while true; do
        show_header
        
        # Load saved IP
        if [ -f "$CONFIG_DIR/ip.conf" ]; then
            LISTENER_IP=$(cat "$CONFIG_DIR/ip.conf")
            IP_STATUS="${GREEN}$LISTENER_IP${NC}"
        else
            IP_STATUS="${RED}Not configured${NC}"
        fi
        
        echo -e "Target IP: $IP_STATUS  |  Port: ${GREEN}5555${NC}\n"
        
        echo -e "${WHITE}╔════════════════════════════════════════╗${NC}"
        echo -e "${WHITE}║           MAIN MENU                    ║${NC}"
        echo -e "${WHITE}╠════════════════════════════════════════╣${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}1)${NC}  Configure IP Address              ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}2)${NC}  ADB Wireless Connection           ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}3)${NC}  Screen Mirroring                  ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}4)${NC}  File Manager                      ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}5)${NC}  Device Control                    ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}6)${NC}  Custom App Listener               ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}7)${NC}  Quick Connect (ADB + scrcpy)      ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}8)${NC}  View Connection Info              ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${RED}9)${NC}  Exit                              ${WHITE}║${NC}"
        echo -e "${WHITE}╚════════════════════════════════════════╝${NC}"
        echo
        read -p "Enter your choice [1-9]: " main_choice
        
        case $main_choice in
            1) configure_ip ;;
            2) menu_adb_wireless ;;
            3) menu_screen_mirror ;;
            4) menu_file_manager ;;
            5) menu_device_control ;;
            6) menu_python_listener ;;
            7)
                echo -e "\n${YELLOW}[*] Quick Connect:${NC}"
                echo "1. Ensure phone is connected via USB"
                echo "2. Enable USB debugging"
                read -p "Press Enter when ready..."
                
                adb tcpip 5555
                echo -e "\n${YELLOW}Now disconnect USB and press Enter${NC}"
                read -p ""
                
                adb connect $LISTENER_IP:5555
                sleep 2
                scrcpy
                ;;
            8)
                show_header
                echo -e "${GREEN}=== CONNECTION INFORMATION ===${NC}\n"
                echo "Your IP: $(hostname -I | awk '{print $1}')"
                echo "Configured IP: $LISTENER_IP"
                echo "ADB port: 5555"
                echo "Custom app port: 5555"
                echo ""
                echo "Connected devices:"
                adb devices
                echo ""
                read -p "Press Enter..."
                ;;
            9)
                echo -e "\n${GREEN}Goodbye!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid option${NC}"
                sleep 2
                ;;
        esac
    done
}

# Check dependencies on startup
check_dependencies

# Start the menu
main_menu
