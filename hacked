# Main program loop
main() {
    show_banner
    check_dependencies
    
    # Initial target setup
    while true; do
        echo -e "${YELLOW}Enter target IP address to scan:${NC} "
        read -r TARGET
        if validate_ip "$TARGET"; then
            echo -e "${GREEN}[✓] Target set to $TARGET${NC}"
            break
        else
            echo -e "${RED}[!] Invalid IP address. Please try again.${NC}"
        fi
    done
    
    # Main menu loop
    while true; do
        show_menu
        echo -e "\n${YELLOW}Enter your choice [0-9]:${NC} "
        read -r choice
        
        case $choice in
            1)
                tcp_connect_scan
                ;;
            2)
                syn_scan
                ;;
            3)
                udp_scan
                ;;
            4)
                nmap_aggressive
                ;;
            5)
                bypass_scan
                ;;
            6)
                service_detect
                ;;
            7)
                set_port_range
                ;;
            8)
                set_target
                ;;
            9)
                show_settings
                ;;
            0)
                echo -e "\n${GREEN}[✓] Thank you for using Toph41k Port Scanner!${NC}"
                echo -e "${YELLOW}Remember: Always scan responsibly!${NC}\n"
                exit 0
                ;;
            *)
                echo -e "${RED}[!] Invalid option. Please choose 0-9.${NC}"
                sleep 2
                ;;
        esac
        
        echo -e "\n${PURPLE}Press Enter to continue...${NC}"
        read -r
    done
}

# Run the main function
main
