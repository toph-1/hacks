build_termux_client() {
    cat > "$DESKTOP_DIR/termux_client.py" << EOF
#!/usr/bin/env python3
"""
Termux Client - Run this on your Android phone
Copy this file to your phone and run in Termux
"""

import socket
import cv2
import numpy as np
import struct
import threading
import time
import os

# === CONFIGURATION - CHANGE THESE ===
SERVER_IP = "$LISTENER_IP"
SERVER_PORT = $LISTENER_PORT
# ====================================

class RemoteClient:
    def __init__(self):
        self.socket = None
        self.running = True
        self.camera = None
        self.streaming = False
    
    def connect(self):
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.connect((SERVER_IP, SERVER_PORT))
            print(f"\033[92m[+] Connected to {SERVER_IP}:{SERVER_PORT}\033[0m")
            
            # Send device info
            info = f"INFO:{os.environ.get('MODEL', 'Android')}|Android"
            self.socket.send((info + "\n").encode())
            return True
        except Exception as e:
            print(f"\033[91m[-] Connection failed: {e}\033[0m")
            return False
    
    def start_stream(self):
        self.streaming = True
        self.camera = cv2.VideoCapture(1)  # 0 for back camera
        
        while self.streaming and self.running:
            try:
                ret, frame = self.camera.read()
                if ret:
                    _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 70])
                    data = buffer.tobytes()
                    
                    self.socket.send(struct.pack('!I', len(data)))
                    self.socket.send(data)
                    
                    cv2.imshow('Sending...', frame)
                    if cv2.waitKey(1) & 0xFF == ord('q'):
                        break
                time.sleep(0.03)
            except Exception as e:
                print(f"Stream error: {e}")
                break
    
    def run(self):
        if not self.connect():
            return
        
        while self.running:
            cmd = input("> ")
            if cmd == "stream":
                self.socket.send(b"START_STREAM\n")
                threading.Thread(target=self.start_stream).start()
            elif cmd == "stop":
                self.socket.send(b"STOP_STREAM\n")
                self.streaming = False
            elif cmd == "exit":
                self.running = False
                break
        
        if self.camera:
            self.camera.release()
        cv2.destroyAllWindows()
        self.socket.close()

if __name__ == "__main__":
    client = RemoteClient()
    client.run()
EOF

    echo -e "${GREEN}✓ Termux client saved to: $DESKTOP_DIR/termux_client.py${NC}"
}

