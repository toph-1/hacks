#!/bin/bash

# =============================================
# Android Remote Access APK with Screen Streaming
# Usage: ./make-apk.sh <LISTENER_IP> <LISTENER_PORT>
# =============================================

LISTENER_IP="$1"
LISTENER_PORT="$2"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check arguments
if [ $# -ne 2 ]; then
    echo -e "${RED}Usage: $0 <YOUR_IP> <PORT>${NC}"
    echo "Example: $0 192.168.1.100 4444"
    exit 1
fi

# Check and fix Java version
check_java_version() {
    echo -e "${YELLOW}[1/8] Checking Java version...${NC}"
    
    if command -v java &> /dev/null; then
        JAVA_VERSION=$(java -version 2>&1 | head -n 1 | awk -F '"' '{print $2}' | awk -F. '{print $1}')
        echo "Found Java version: $JAVA_VERSION"
        
        if [ "$JAVA_VERSION" -ge 18 ]; then
            echo -e "${YELLOW}Java $JAVA_VERSION detected. Installing Java 17...${NC}"
            sudo apt update -y
            sudo apt install -y openjdk-17-jdk
            export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
            export PATH=$JAVA_HOME/bin:$PATH
            echo -e "${GREEN}✓ Now using Java 17${NC}"
        else
            echo -e "${GREEN}✓ Java version $JAVA_VERSION is compatible${NC}"
        fi
    else
        echo -e "${YELLOW}Installing Java 17...${NC}"
        sudo apt update -y
        sudo apt install -y openjdk-17-jdk
    fi
}

# Check requirements
check_requirements() {
    echo -e "${YELLOW}[2/8] Installing requirements...${NC}"
    
    sudo apt update -y
    sudo apt install -y \
        openjdk-17-jdk \
        wget \
        unzip \
        zip \
        apksigner \
        python3 \
        python3-pip \
        python3-tk
    
    pip3 install --user opencv-python numpy pillow
    
    # Download and setup Android SDK
    if [ ! -d "$HOME/Android/Sdk" ]; then
        mkdir -p $HOME/Android/Sdk
        cd $HOME/Android/Sdk
        wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip
        unzip -q commandlinetools-linux-*.zip
        rm commandlinetools-linux-*.zip
        mv cmdline-tools latest
        mkdir -p cmdline-tools
        mv latest cmdline-tools/
    fi
    
    export ANDROID_HOME=$HOME/Android/Sdk
    export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools
    
    # Accept licenses
    yes | $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --licenses > /dev/null 2>&1
    
    # Install SDK components
    $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager "platform-tools" "platforms;android-34" "build-tools;34.0.0"
    
    echo -e "${GREEN}✓ Requirements installed${NC}"
}

# Create Android project
create_project() {
    echo -e "${YELLOW}[3/8] Creating Android project...${NC}"
    
    PROJECT_DIR="$HOME/android-remote-$(date +%s)"
    mkdir -p $PROJECT_DIR/app/src/main/java/com/remote/access
    mkdir -p $PROJECT_DIR/app/src/main/res/layout
    mkdir -p $PROJECT_DIR/app/src/main/res/values
    mkdir -p $PROJECT_DIR/app/src/main/res/mipmap-hdpi
    mkdir -p $PROJECT_DIR/app/src/main/res/mipmap-mdpi
    mkdir -p $PROJECT_DIR/app/src/main/res/mipmap-xhdpi
    mkdir -p $PROJECT_DIR/app/src/main/res/mipmap-xxhdpi
    mkdir -p $PROJECT_DIR/app/src/main/res/mipmap-xxxhdpi
    
    cd $PROJECT_DIR
    
    # Create settings.gradle
    cat > settings.gradle << 'EOF'
include ':app'
rootProject.name = "RemoteAccess"
EOF

    # Create build.gradle
    cat > build.gradle << 'EOF'
buildscript {
    repositories {
        google()
        mavenCentral()
    }
    dependencies {
        classpath 'com.android.tools.build:gradle:8.4.0'
    }
}

allprojects {
    repositories {
        google()
        mavenCentral()
    }
}
EOF

    # Create app/build.gradle
    cat > app/build.gradle << 'EOF'
apply plugin: 'com.android.application'

android {
    namespace 'com.remote.access'
    compileSdk 34
    
    defaultConfig {
        applicationId "com.remote.access"
        minSdk 21
        targetSdk 34
        versionCode 1
        versionName "1.0"
    }
    
    buildTypes {
        release {
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
    }
    
    compileOptions {
        sourceCompatibility JavaVersion.VERSION_17
        targetCompatibility JavaVersion.VERSION_17
    }
}

dependencies {
    implementation 'androidx.appcompat:appcompat:1.6.1'
    implementation 'com.google.android.material:material:1.11.0'
    implementation 'androidx.core:core:1.12.0'
}
EOF

    # Create proguard-rules.pro
    cat > app/proguard-rules.pro << 'EOF'
-keep class com.remote.access.** { *; }
-dontwarn android.**
EOF

    echo -e "${GREEN}✓ Project created${NC}"
}

