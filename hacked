    fi
    
    echo -e "${BLUE}Select bypass technique:${NC}"
    echo -e "${CYAN}[1]${NC} Packet Fragmentation (-f)"
    echo -e "${CYAN}[2]${NC} Decoy Scan (-D RND:10)"
    echo -e "${CYAN}[3]${NC} Randomize Port Order (--randomize-hosts)"
    echo -e "${CYAN}[4]${NC} All Techniques Combined"
    echo -e "${CYAN}[0]${NC} Back to Main Menu"
    
    echo -e "\n${YELLOW}Enter choice:${NC} "
    read -r bypass_choice
    
    case $bypass_choice in
        1)
            echo -e "\n${BLUE}[*] Running fragmented packet scan...${NC}"
            sudo nmap -f $TARGET -p $START_PORT-$END_PORT
            ;;
        2)
            echo -e "\n${BLUE}[*] Running decoy scan with random IPs...${NC}"
            sudo nmap -D RND:10 $TARGET -p $START_PORT-$END_PORT
            ;;
        3)
            echo -e "\n${BLUE}[*] Running scan with randomized ports...${NC}"
            sudo nmap --randomize-hosts -p $START_PORT-$END_PORT $TARGET
            ;;
        4)
            echo -e "\n${BLUE}[*] Running all bypass techniques combined...${NC}"
            sudo nmap -f -D RND:10 --randomize-hosts -p $START_PORT-$END_PORT $TARGET
            ;;
        0)
            return
            ;;
        *)
            echo -e "${RED}[!] Invalid option${NC}"
            ;;
    esac
}

# FIXED: Function for service detection
service_detect() {
    echo -e "\n${CYAN}[*] Detecting services on common ports${NC}\n"
    
    if ! command -v nc &> /dev/null; then
        echo -e "${RED}[!] netcat (nc) is required for service detection${NC}"
        return
    fi
    
    # Common ports to check
    local common_ports=(21 22 23 25 53 80 110 111 135 139 143 443 445 993 995 1723 3306 3389 5900 8080)
    
    echo -e "${BLUE}[*] Checking common ports on $TARGET...${NC}\n"
    
    for port in "${common_ports[@]}"; do
        echo -ne "${YELLOW}[*] Probing port $port...${NC}\r"
        
        # Check if port is open
        if timeout 2 bash -c "echo >/dev/tcp/$TARGET/$port" 2>/dev/null; then
            echo -e "${GREEN}[+] Port $port is OPEN - ${NC}"
            
            # Try to grab banner
            banner=$(timeout 2 nc -vn $TARGET $port 2>&1 | head -3 | tr -d '\n' | cut -c1-50)
            if [ -n "$banner" ] && [ "$banner" != " " ]; then
                echo -e "${GREEN}    Banner: $banner${NC}"
            else
                # Guess service from port number
                case $port in
                    21) echo -e "${BLUE}    Service: FTP${NC}" ;;
                    22) echo -e "${BLUE}    Service: SSH${NC}" ;;
                    23) echo -e "${BLUE}    Service: Telnet${NC}" ;;
                    25) echo -e "${BLUE}    Service: SMTP${NC}" ;;
                    53) echo -e "${BLUE}    Service: DNS${NC}" ;;
                    80) echo -e "${BLUE}    Service: HTTP${NC}" ;;
                    110) echo -e "${BLUE}    Service: POP3${NC}" ;;
                    111) echo -e "${BLUE}    Service: RPC${NC}" ;;
                    135) echo -e "${BLUE}    Service: RPC${NC}" ;;
                    139) echo -e "${BLUE}    Service: NetBIOS${NC}" ;;
                    143) echo -e "${BLUE}    Service: IMAP${NC}" ;;
                    443) echo -e "${BLUE}    Service: HTTPS${NC}" ;;
                    445) echo -e "${BLUE}    Service: SMB${NC}" ;;
                    993) echo -e "${BLUE}    Service: IMAPS${NC}" ;;
                    995) echo -e "${BLUE}    Service: POP3S${NC}" ;;
                    1723) echo -e "${BLUE}    Service: PPTP${NC}" ;;
                    3306) echo -e "${BLUE}    Service: MySQL${NC}" ;;
                    3389) echo -e "${BLUE}    Service: RDP${NC}" ;;
                    5900) echo -e "${BLUE}    Service: VNC${NC}" ;;
                    8080) echo -e "${BLUE}    Service: HTTP-Alt${NC}" ;;
                    *) echo -e "${YELLOW}    Service: Unknown${NC}" ;;
                esac
            fi
        fi
    done
    echo -e "\n${GREEN}[✓] Service detection complete${NC}"
}

# FIXED: Function to set custom port range
set_port_range() {
    echo -e "\n${CYAN}[*] Current port range: $START_PORT-$END_PORT${NC}"
    echo -e "${YELLOW}Enter new port range (e.g., 1-1000):${NC} "
    read -r range
    
    if [[ $range =~ ^[0-9]+-[0-9]+$ ]]; then
        START_PORT=$(echo $range | cut -d'-' -f1)
        END_PORT=$(echo $range | cut -d'-' -f2)
        if [ $START_PORT -lt 1 ] || [ $END_PORT -gt 65535 ] || [ $START_PORT -gt $END_PORT ]; then
            echo -e "${RED}[!] Invalid port range. Using default 1-1024.${NC}"
            START_PORT=1
            END_PORT=1024
        else
            echo -e "${GREEN}[✓] Port range set to $START_PORT-$END_PORT${NC}"
        fi
    else
        echo -e "${RED}[!] Invalid format. Using previous range.${NC}"
    fi
}

# FIXED: Function to set target
set_target() {
    echo -e "\n${CYAN}[*] Current target: $TARGET${NC}"
    echo -e "${YELLOW}Enter target IP address:${NC} "
    read -r new_target
    
    if validate_ip "$new_target"; then
        TARGET=$new_target
        echo -e "${GREEN}[✓] Target set to $TARGET${NC}"
    else
        echo -e "${RED}[!] Invalid IP address. Please try again.${NC}"
    fi
}

