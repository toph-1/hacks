#!/usr/bin/env python3
import socket
import cv2
import numpy as np
import struct
import time
import threading

SERVER_IP = "$LISTENER_IP"
SERVER_PORT = $LISTENER_PORT

def send_frame(client, frame):
    try:
        # Encode frame as JPEG
        _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 70])
        data = buffer.tobytes()
        
        # Send size and data
        client.send(struct.pack('!I', len(data)))
        client.send(data)
    except Exception as e:
        print(f"Send error: {e}")

def main():
    # Connect to server
    client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    client.connect(('$LISTENER_IP', $LISTENER_PORT))
    print(f"Connected to $LISTENER_IP:$LISTENER_PORT")
    
    # Get welcome message
    print(client.recv(1024).decode())
    
    # Get camera
    cap = cv2.VideoCapture(1)  # 0 for back camera
    
    while True:
        ret, frame = cap.read()
        if ret:
            send_frame(client, frame)
            cv2.imshow('Sending...', frame)
            if cv2.waitKey(1) & 0xFF == ord('q'):
                break
    
    cap.release()
    cv2.destroyAllWindows()
    client.close()

if __name__ == "__main__":
    main()
