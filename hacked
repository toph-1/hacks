        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remote Access App"
        android:textSize="24sp"
        android:layout_gravity="center"/>
</LinearLayout>
""")

# Create AndroidManifest.xml
with open(os.path.join(temp_dir, "AndroidManifest.xml"), "w") as f:
    f.write("""
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.remote.access">
    <application
        android:label="Remote Access">
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
""")

# Create a zip file
with zipfile.ZipFile(os.path.expanduser("~/remote-access-app.zip"), "w") as zipf:
