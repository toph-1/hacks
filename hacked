#!/bin/bash

# =============================================
# ANDROID APK BUILDER - WITH YOUR IP & PORT
# Creates a real APK that connects to your server
# =============================================

# Configuration
CONFIG_DIR="$HOME/.android-builder"
LISTENER_IP=""
LISTENER_PORT="4444"
APK_NAME="RemoteAccess"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Create config directory
mkdir -p "$CONFIG_DIR"

# Function to show header
show_header() {
    clear
    echo -e "${BLUE}"
    echo "╔════════════════════════════════════════════════════════╗"
    echo "║        ANDROID APK BUILDER - WITH YOUR IP             ║"
    echo "║     Creates APK that connects to YOUR server          ║"
    echo "╚════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Function to set IP and port
configure_ip_port() {
    show_header
    echo -e "${CYAN}=== CONFIGURE CONNECTION SETTINGS ===${NC}\n"
    
    # Get local IP
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    echo -e "Your computer's IP: ${GREEN}$LOCAL_IP${NC}"
    
    # Load saved settings if they exist
    if [ -f "$CONFIG_DIR/settings.conf" ]; then
        source "$CONFIG_DIR/settings.conf"
        echo -e "Saved IP: ${YELLOW}$SAVED_IP${NC}"
        echo -e "Saved Port: ${YELLOW}$SAVED_PORT${NC}"
        LISTENER_IP="$SAVED_IP"
        LISTENER_PORT="$SAVED_PORT"
    fi
    
    echo ""
    read -p "Enter IP address for APK to connect to [$LISTENER_IP]: " input_ip
    LISTENER_IP=${input_ip:-$LISTENER_IP}
    
    read -p "Enter port number [$LISTENER_PORT]: " input_port
    LISTENER_PORT=${input_port:-$LISTENER_PORT}
    
    # Save settings
    echo "SAVED_IP=$LISTENER_IP" > "$CONFIG_DIR/settings.conf"
    echo "SAVED_PORT=$LISTENER_PORT" >> "$CONFIG_DIR/settings.conf"
    
    echo -e "${GREEN}✓ Settings saved: $LISTENER_IP:$LISTENER_PORT${NC}"
    sleep 2
}

# Function to check and install dependencies
install_dependencies() {
    show_header
    echo -e "${CYAN}=== CHECKING DEPENDENCIES ===${NC}\n"
    
    MISSING=()
    
    # Check Java
    if ! command -v javac &> /dev/null; then
        MISSING+=("openjdk-17-jdk")
    fi
    
    # Check Android SDK
    if [ ! -d "$HOME/Android/Sdk" ]; then
        MISSING+=("android-sdk")
    fi
    
    # Check gradle
    if ! command -v gradle &> /dev/null; then
        MISSING+=("gradle")
    fi
    
    if [ ${#MISSING[@]} -gt 0 ]; then
        echo -e "${YELLOW}Missing dependencies: ${MISSING[*]}${NC}"
        read -p "Install now? (y/n): " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            sudo apt update
            sudo apt install -y openjdk-17-jdk wget unzip zip gradle
            
            # Install Android SDK
            if [ ! -d "$HOME/Android/Sdk" ]; then
                echo -e "${YELLOW}Installing Android SDK...${NC}"
                mkdir -p $HOME/Android/Sdk
                cd $HOME/Android/Sdk
                wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip
                unzip -q commandlinetools-linux-*.zip
                rm commandlinetools-linux-*.zip
                mv cmdline-tools latest
                mkdir -p cmdline-tools
                mv latest cmdline-tools/
                
                # Set environment variables
                export ANDROID_HOME=$HOME/Android/Sdk
                export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools
                
                # Accept licenses
                yes | $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --licenses > /dev/null 2>&1
                
                # Install SDK components
                $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager "platform-tools" "platforms;android-34" "build-tools;34.0.0"
            fi
            
            echo -e "${GREEN}✓ All dependencies installed${NC}"
        fi
    else
        echo -e "${GREEN}✓ All dependencies found${NC}"
    fi
    
    sleep 2
}

