}

# Main
main() {
    clear
    echo -e "${BLUE}Android Remote Access APK Generator${NC}\n"
    
    check_java_version
    check_requirements
    create_project
    create_manifest
    create_java_code
    build_apk
    sign_apk
    create_listener
    show_instructions
}

main "$@"
