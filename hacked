package com.remote.control;

import android.app.Service;
import android.content.Intent;
import android.os.IBinder;
import android.util.Log;
import java.io.*;
import java.net.*;
import android.widget.Toast;
import android.os.Handler;
import android.os.Looper;

public class RemoteService extends Service {
    private static final String TAG = "RemoteService";
    private Socket socket;
    private PrintWriter out;
    private DataOutputStream dataOut;
    private Thread connectionThread;
    private boolean connected = false;
    
    @Override
    public int onStartCommand(Intent intent, int flags, int startId) {
        String ip = intent.getStringExtra("ip");
        int port = intent.getIntExtra("port", $LISTENER_PORT);
        String command = intent.getStringExtra("command");
        
        if (command != null) {
            sendCommand(command);
        } else {
            connectToServer(ip, port);
        }
        
        return START_STICKY;
    }
    
    private void connectToServer(String ip, int port) {
        connectionThread = new Thread(() -> {
            try {
                socket = new Socket(ip, port);
                out = new PrintWriter(socket.getOutputStream(), true);
                dataOut = new DataOutputStream(socket.getOutputStream());
                connected = true;
                
                showToast("Connected to " + ip);
                
                // Send device info
                String info = android.os.Build.MODEL + "|" + 
                             android.os.Build.VERSION.RELEASE;
                out.println("INFO:" + info);
                
                // Listen for commands
                BufferedReader in = new BufferedReader(
                    new InputStreamReader(socket.getInputStream()));
                String command;
                while ((command = in.readLine()) != null) {
                    handleCommand(command);
                }
                
            } catch (Exception e) {
                showToast("Connection failed: " + e.getMessage());
                Log.e(TAG, "Connection error", e);
            }
        });
        connectionThread.start();
    }
    
    private void handleCommand(String command) {
        if (command.equals("START_STREAM")) {
            showToast("Starting stream...");
        } else if (command.equals("STOP_STREAM")) {
            showToast("Stopping stream...");
        } else if (command.equals("PING")) {
            out.println("PONG");
        }
    }
    
    private void sendCommand(String cmd) {
        if (out != null) {
            if (cmd.equals("stream")) {
                out.println("START_STREAM");
            } else if (cmd.equals("stop")) {
                out.println("STOP_STREAM");
            } else if (cmd.equals("info")) {
                out.println("INFO");
            }
        }
    }
    
    private void showToast(final String message) {
        new Handler(Looper.getMainLooper()).post(() -> 
            Toast.makeText(RemoteService.this, message, Toast.LENGTH_SHORT).show()
        );
    }
    
    @Override
    public IBinder onBind(Intent intent) {
        return null;
    }
    
    @Override
    public void onDestroy() {
        connected = false;
        try {
            if (socket != null) socket.close();
        } catch (Exception e) {}
        super.onDestroy();
    }
}
