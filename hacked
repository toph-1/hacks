// DroidScript Remote Access App
// Copy this code into DroidScript to build APK

var ip = "$LISTENER_IP";
var port = $LISTENER_PORT;
var socket;

function OnStart() {
    // Create layout
    var lay = app.CreateLayout("linear", "FillXY");
    lay.SetBackground("#2196F3");
    
    // Title
    var title = app.CreateText("Remote Access");
    title.SetTextSize(32);
    title.SetTextColor("#FFFFFF");
    title.SetMargins(0, 50, 0, 0);
    lay.AddChild(title);
    
    // Server info
    var info = app.CreateText(ip + ":" + port);
    info.SetTextSize(20);
    info.SetTextColor("#FFD700");
    info.SetMargins(0, 20, 0, 50);
    lay.AddChild(info);
    
    // Connect button
    var btnConnect = app.CreateButton("Connect to Server", 0.7, 0.1);
    btnConnect.SetTextColor("#2196F3");
    btnConnect.SetBackground("#FFFFFF");
    btnConnect.SetOnClick(btnConnect_OnClick);
    lay.AddChild(btnConnect);
    
    // Status
    var status = app.CreateText("Not connected");
    status.SetTextSize(16);
    status.SetTextColor("#FFFFFF");
    status.SetMargins(0, 30, 0, 30);
    lay.AddChild(status);
    
    // Control buttons (initially hidden)
    var btnStream = app.CreateButton("Start Camera", 0.6, 0.1);
    btnStream.SetTextColor("#2196F3");
    btnStream.SetBackground("#4CAF50");
    btnStream.SetTextColor("#FFFFFF");
    btnStream.SetMargins(0, 10, 0, 0);
    btnStream.SetOnClick(btnStream_OnClick);
    btnStream.SetVisibility(false);
    lay.AddChild(btnStream);
    
    var btnStop = app.CreateButton("Stop Camera", 0.6, 0.1);
    btnStop.SetTextColor("#2196F3");
    btnStop.SetBackground("#F44336");
    btnStop.SetTextColor("#FFFFFF");
    btnStop.SetMargins(0, 10, 0, 0);
    btnStop.SetOnClick(btnStop_OnClick);
    btnStop.SetVisibility(false);
    lay.AddChild(btnStop);
    
    var btnPhoto = app.CreateButton("Take Photo", 0.6, 0.1);
    btnPhoto.SetTextColor("#2196F3");
    btnPhoto.SetBackground("#FF9800");
    btnPhoto.SetTextColor("#FFFFFF");
    btnPhoto.SetMargins(0, 10, 0, 0);
    btnPhoto.SetOnClick(btnPhoto_OnClick);
    btnPhoto.SetVisibility(false);
    lay.AddChild(btnPhoto);
    
    app.AddLayout(lay);
    
    function btnConnect_OnClick() {
        status.SetText("Connecting...");
        socket = app.CreateTCPClient();
        socket.SetOnConnect(socket_OnConnect);
        socket.SetOnError(socket_OnError);
        socket.Connect(ip, port);
    }
    
    function socket_OnConnect() {
        status.SetText("Connected!");
        btnConnect.SetVisibility(false);
        btnStream.SetVisibility(true);
        btnStop.SetVisibility(true);
        btnPhoto.SetVisibility(true);
        
        // Send device info
        var info = "INFO:" + app.GetDeviceInfo();
        socket.Write(info + "\\n");
    }
    
    function socket_OnError(error) {
        status.SetText("Error: " + error);
    }
    
    function btnStream_OnClick() {
        socket.Write("START_CAMERA\\n");
        status.SetText("Starting camera...");
    }
    
    function btnStop_OnClick() {
        socket.Write("STOP_CAMERA\\n");
        status.SetText("Stopping camera...");
    }
    
    function btnPhoto_OnClick() {
        socket.Write("TAKE_PHOTO\\n");
        status.SetText("Taking photo...");
    }
}
