echo "pip install numpy"
echo ""
echo "Then create client.py with the code provided"
echo ""
echo "Run with: python client.py"
EOF

    echo -e "${GREEN}✓ Termux client created at: $CONFIG_DIR/termux_client.py${NC}"
    echo ""
