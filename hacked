#!/bin/bash

# =============================================
# ANDROID REMOTE CONTROL - WORKING SOLUTION
# Uses ADB + Scrcpy (Official Google Tools)
# These tools ALWAYS work!
# =============================================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Desktop path
DESKTOP="$HOME/Desktop"
mkdir -p "$DESKTOP"

# =============================================
# INSTALL ADB AND SCRCPY (These actually work!)
# =============================================

install_tools() {
    echo -e "${YELLOW}Installing ADB and Scrcpy...${NC}"
    sudo apt update
    sudo apt install -y adb scrcpy
    echo -e "${GREEN}✓ Tools installed${NC}"
}

# =============================================
# METHOD 1: ADB + SCRCPY (WORKS 100%)
# =============================================

method_adb_scrcpy() {
    clear
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     METHOD 1: ADB + SCRCPY            ║${NC}"
    echo -e "${BLUE}║     This ALWAYS works!                 ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
    echo ""
    
    # Check if tools installed
    if ! command -v adb &> /dev/null; then
        install_tools
    fi
    
    echo -e "${GREEN}Step 1: Connect your phone via USB${NC}"
    echo -e "${GREEN}Step 2: Enable USB Debugging on your phone${NC}"
    echo -e "${GREEN}Step 3: When prompted on phone, allow debugging${NC}"
    echo ""
    read -p "Press Enter when ready..."
    
    # Check devices
    echo ""
    echo -e "${YELLOW}Checking connected devices...${NC}"
    adb devices
    
    echo ""
    echo -e "${GREEN}Step 4: Switch to wireless mode${NC}"
    adb tcpip 5555
    
    echo ""
    echo -e "${GREEN}Step 5: Disconnect USB cable${NC}"
    read -p "Press Enter after disconnecting USB..."
    
    # Get phone IP
    echo ""
    echo -e "${YELLOW}Getting phone IP...${NC}"
    PHONE_IP=$(adb shell ip -f inet addr show wlan0 | grep inet | awk '{print $2}' | cut -d/ -f1)
    
    if [ -z "$PHONE_IP" ]; then
        echo "Could not detect phone IP automatically"
        read -p "Enter phone IP address: " PHONE_IP
    fi
    
    echo ""
    echo -e "${GREEN}Phone IP: $PHONE_IP${NC}"
    echo -e "${YELLOW}Connecting wirelessly...${NC}"
    adb connect $PHONE_IP:5555
    
    echo ""
    echo -e "${GREEN}✓ Connected! Starting screen mirror...${NC}"
    echo -e "${YELLOW}The phone screen will appear in a new window${NC}"
    echo -e "${YELLOW}You can control it with mouse/keyboard${NC}"
    echo ""
    sleep 2
    
    # Start scrcpy
    scrcpy
    
    echo ""
    read -p "Press Enter to continue..."
}

# =============================================
# METHOD 2: APK USING WEBSITE BUILDER
# =============================================

method_website_apk() {
