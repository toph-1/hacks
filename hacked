            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }
        button {
            padding: 20px;
            font-size: 18px;
            border: none;
            border-radius: 10px;
            background: white;
            color: #667eea;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
        }
        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }
        .stream-btn { background: #ff6b6b; color: white; }
        .stop-btn { background: #feca57; color: white; }
        .status {
            margin-top: 30px;
            padding: 15px;
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            font-family: monospace;
            text-align: center;
        }
        .ip-display {
            font-size: 24px;
            font-weight: bold;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📱 Remote Control</h1>
        
        <div class="info-box">
            <div>Connecting to:</div>
            <div class="ip-display">$LISTENER_IP:$LISTENER_PORT</div>
        </div>
        
        <div class="button-grid">
            <button onclick="sendCommand('stream')" class="stream-btn">▶ START STREAM</button>
            <button onclick="sendCommand('stop')" class="stop-btn">⏹ STOP STREAM</button>
            <button onclick="sendCommand('info')">ℹ DEVICE INFO</button>
            <button onclick="sendCommand('ping')">🏓 PING</button>
            <button onclick="sendCommand('screenshot')">📸 SCREENSHOT</button>
            <button onclick="sendCommand('shell ls')">📁 LIST FILES</button>
        </div>
        
        <div class="status" id="status">
            Ready to connect...
        </div>
    </div>
    
    <script>
        const serverUrl = 'http://$LISTENER_IP:$LISTENER_PORT';
        const statusEl = document.getElementById('status');
        
        function sendCommand(cmd) {
            statusEl.innerHTML = `Sending: \${cmd}...`;
            statusEl.style.background = 'rgba(255,193,7,0.3)';
            
            fetch(`\${serverUrl}/\${cmd}`)
                .then(response => response.text())
                .then(data => {
                    statusEl.innerHTML = `Response: \${data}`;
                    statusEl.style.background = 'rgba(76,175,80,0.3)';
                })
                .catch(error => {
                    statusEl.innerHTML = `Error: \${error}`;
                    statusEl.style.background = 'rgba(244,67,54,0.3)';
                });
        }
        
        // Check connection every 5 seconds
        function checkConnection() {
            fetch(`\${serverUrl}/ping`)
                .then(response => response.text())
                .then(data => {
                    statusEl.innerHTML = '✅ Connected';
                    statusEl.style.background = 'rgba(76,175,80,0.3)';
                })
                .catch(error => {
                    statusEl.innerHTML = '❌ Disconnected';
                    statusEl.style.background = 'rgba(244,67,54,0.3)';
                });
        }
        
        checkConnection();
        setInterval(checkConnection, 5000);
    </script>
</body>
</html>
EOF

    echo -e "${GREEN}✓ Webpage saved to: $DESKTOP_DIR/remote_control.html${NC}"
    echo -e "${YELLOW}Use this with online APK builders like appsgeyser.com${NC}"
