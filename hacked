                    sleep 2
                fi
                ;;
            2) build_webview_apk ;;
            3) build_termux_apk ;;
            4) build_mit_app ;;
            5) build_online_apk ;;
            6) build_studio_template ;;
            7) configure_ip_port ;;
            8) install_dependencies ;;
            9) 
                echo -e "\n${GREEN}Goodbye!${NC}"
                exit 0 
                ;;
            *) 
                echo -e "${RED}Invalid option${NC}"
                sleep 2
                ;;
        esac
    done
}

