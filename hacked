    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order to eventually append to the command
# when we start consuming arguments may begin with the virtual memory maximum offer (A.K.A. stack size).
# We could use "${1+ "$@"}" to make the positional parameters re-ordered, but it looks like that's busted.
set --
for argv in "$@"; do
    case $argv in
      -D*)
        # Scripted args, consume them as we see them.
        set -- "$@" "$argv"
        ;;
      *)
        # Consume non-D options after them.
        set -- "$@" "$argv"
        ;;
    esac
done

# Collect all arguments for the java command;
#   * $DEFAULT_JVM_OPTS, $JAVA_OPTS, and $GRADLE_OPTS can contain fragments of
#     shell script including quotes and variable substitutions, so put them in
#     double quotes to make sure that they get re-expanded; and
#   * put everything else in double quotes, too.
set -- $DEFAULT_JVM_OPTS "$JAVA_OPTS" "$GRADLE_OPTS" "$@"

# Use "xargs" to parse quoted args.
#
# With -n1 it outputs one arg per line, with the quotes and backslashes removed.
#
# This is safe because the only special character we care about is the
# argument separator. We don't have to worry about escapes because we're
# passing through xargs parsing.
#
# Use "xargs" to parse the args, then pass the rest to java.
#
# As an alternative, we could use "eval" to allow the args to be
# treated as one long string. But that would also allow arbitrary
# code execution, which is not what we want.
#
# Also note, we rely on the default IFS value, which is " \t\n".
# shellcheck disable=SC2162
parseJvmArgs() (
    IFS=' 
'
    for arg in $1; do
        # We can't use echo directly; it would re-interpret special characters.
        # Instead, use the percent sign as the only escape mechanism.
        # It's also important to note that we can't use xargs's -0 because that
        # would also remove the escapes from the arguments that don't need them.
        # Use awk to do the parsing.
        # We also can't just assume that the entire argument is one big string;
        # the quoting might be at the individual argument level.
        # Instead, we need to handle each argument as its own entity.
        printf "%s\n" "$arg" | awk '
            # Separate the arguments by newline
            BEGIN { RS="\n"; }
            {
                # Escape the percent sign
                gsub(/%/, "%%");
                # Replace all backslashes with double backslashes
                gsub(/\\/, "\\\\");
                # Remove quotes if they are the first and last character
                if (substr($0, 1, 1) == "\"" && substr($0, length($0), 1) == "\"") {
                    $0 = substr($0, 2, length($0)-2);
                }
                # Print the argument with newline
                printf "%s\n", $0;
            }
        ' | while read -r arg; do
            # Escape any remaining special characters
            arg=$(printf "%s" "$arg" | sed 's/[$`"\\]/\\&/g')
            # Add the argument to the list
            set -- "$@" "$arg"
        done
    done
)

# Parse the arguments and add them to the command line
parseJvmArgs "$@"

# Split up the JVM_OPTS And GRADLE_OPTS values into an array, following the shell quoting and substitution rules.
# Remove the use of eval because it causes issues with argument quoting.
# We'll just use the string as-is and let the shell handle it.
JVM_OPTS_COMBINED="$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS"

# Remove leading/trailing whitespace
JVM_OPTS_COMBINED=$(echo "$JVM_OPTS_COMBINED" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

# Prepare the command for execution.
# Note the use of "set -- $args" to set the positional parameters in the order they appear.
# This is safe because we're not using any of the positional parameters in the command itself.
set -- $JVM_OPTS_COMBINED -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"

# Start the JVM
exec "$JAVACMD" "$@"
