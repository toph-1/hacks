# Configuration
CONFIG_DIR="$HOME/.android-remote"
LISTENER_IP=""
LISTENER_PORT="4444"
DESKTOP_DIR="$HOME/Desktop"
LOG_FILE="$CONFIG_DIR/control.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# Create config directory
mkdir -p "$CONFIG_DIR"
mkdir -p "$CONFIG_DIR/listener_logs"

# Check if Desktop exists (might be called different in non-English systems)
if [ ! -d "$DESKTOP_DIR" ]; then
    # Try alternative desktop names
    if [ -d "$HOME/Desktop" ]; then
        DESKTOP_DIR="$HOME/Desktop"
    elif [ -d "$HOME/Escritorio" ]; then
        DESKTOP_DIR="$HOME/Escritorio"
    elif [ -d "$HOME/Skrivbord" ]; then
        DESKTOP_DIR="$HOME/Skrivbord"
    else
        # Create Desktop if it doesn't exist
        mkdir -p "$HOME/Desktop"
        DESKTOP_DIR="$HOME/Desktop"
    fi
fi

