    clear
    echo -e "${GREEN}"
    echo "╔════════════════════════════════════════════╗"
    echo "║              SETUP COMPLETE!               ║"
    echo "╚════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo -e "${YELLOW}APK:${NC} $HOME/remote-access-$LISTENER_IP-$LISTENER_PORT.apk"
    echo -e "${YELLOW}Listener:${NC} python3 ~/android-listener.py"
