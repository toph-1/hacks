# Function to build with Termux (Option 3)
build_termux_apk() {
    show_header
    echo -e "${CYAN}=== BUILD WITH TERMUX (RUNS ON PHONE) ===${NC}\n"
    echo -e "Target server: ${GREEN}$LISTENER_IP:$LISTENER_PORT${NC}\n"
    
    # Create Python script for Termux
    cat > "$CONFIG_DIR/termux_client.py" << EOF
#!/usr/bin/env python3
"""
Termux Client - Run this on your Android phone
Install Termux from F-Droid first!
"""

import socket
import cv2
import numpy as np
import struct
import time
import threading

# === CONFIGURATION - EDIT THESE ===
SERVER_IP = "$LISTENER_IP"
SERVER_PORT = $LISTENER_PORT
# ================================

class RemoteClient:
    def __init__(self):
        self.socket = None
        self.running = True
        self.camera = None
    
    def connect(self):
        """Connect to server"""
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.connect((SERVER_IP, SERVER_PORT))
            print(f"[+] Connected to {SERVER_IP}:{SERVER_PORT}")
            return True
        except Exception as e:
            print(f"[-] Connection failed: {e}")
            return False
    
    def start_stream(self):
        """Start sending camera feed"""
        self.camera = cv2.VideoCapture(1)  # 0 for back camera, 1 for front
        
        while self.running:
            try:
                ret, frame = self.camera.read()
                if ret:
                    # Compress frame
                    _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 70])
                    data = buffer.tobytes()
                    
                    # Send size + data
                    self.socket.send(struct.pack('!I', len(data)))
                    self.socket.send(data)
                    
                    # Show preview
                    cv2.imshow('Sending...', frame)
                    if cv2.waitKey(1) & 0xFF == ord('q'):
                        break
                time.sleep(0.03)  # ~30 fps
            except Exception as e:
                print(f"Stream error: {e}")
                break
    
    def run(self):
        """Main loop"""
        if not self.connect():
            return
        
        # Start streaming
        self.start_stream()
        
        # Cleanup
        if self.camera:
            self.camera.release()
        cv2.destroyAllWindows()
        self.socket.close()

if __name__ == "__main__":
    client = RemoteClient()
    client.run()
EOF

    # Create installation script for Termux
    cat > "$CONFIG_DIR/termux_install.sh" << EOF
