#!/usr/bin/env python3
import socket
import cv2
import numpy as np
import struct

server_ip = "$IP"
server_port = $LISTENER_PORT

client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
client.connect((server_ip, server_port))
