#!/bin/bash

# =============================================
# ANDROID REMOTE ACCESS APK BUILDER
# This creates a REAL APK file on your Desktop
# =============================================

# Configuration
DESKTOP="$HOME/Desktop"
APK_NAME="RemoteAccess"
PACKAGE_NAME="com.remote.access"
LISTENER_IP=""
LISTENER_PORT="4444"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Create Desktop folder
mkdir -p "$DESKTOP"

# =============================================
# CHECK AND INSTALL DEPENDENCIES
# =============================================

check_dependencies() {
    echo -e "${YELLOW}Checking dependencies...${NC}"
    
    # Check Java
    if ! command -v java &> /dev/null; then
        echo "Installing Java..."
        sudo apt update
        sudo apt install -y openjdk-17-jdk
    fi
    
    # Check Android SDK
    if [ ! -d "$HOME/Android/Sdk" ]; then
        echo "Downloading Android SDK..."
        mkdir -p "$HOME/Android/Sdk"
        cd "$HOME/Android/Sdk"
        wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip
        unzip -q commandlinetools-linux-*.zip
        rm commandlinetools-linux-*.zip
        mv cmdline-tools latest
        mkdir -p cmdline-tools
        mv latest cmdline-tools/
        
        # Set environment variables
        export ANDROID_HOME="$HOME/Android/Sdk"
        export PATH="$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools"
        
        # Accept licenses
        yes | $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --licenses > /dev/null 2>&1
        
        # Install SDK components
        $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager "platform-tools" "platforms;android-34" "build-tools;34.0.0"
    fi
    
    echo -e "${GREEN}✓ Dependencies ready${NC}"
}

# =============================================
# CONFIGURE IP AND PORT
# =============================================

configure_settings() {
    clear
    echo -e "${BLUE}=== CONFIGURE CONNECTION SETTINGS ===${NC}\n"
    
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    echo -e "Your computer's IP: ${GREEN}$LOCAL_IP${NC}"
    echo ""
    
    read -p "Enter IP address for APK to connect to [$LOCAL_IP]: " input_ip
    LISTENER_IP=${input_ip:-$LOCAL_IP}
    
    read -p "Enter port number [$LISTENER_PORT]: " input_port
    LISTENER_PORT=${input_port:-$LISTENER_PORT}
    
    echo -e "${GREEN}✓ Settings saved: $LISTENER_IP:$LISTENER_PORT${NC}"
    sleep 2
}

