    echo ""
    
    # Get local IP
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    
    # Create HTML file on Desktop
    cat > "$DESKTOP/remote_control.html" << EOF
<!DOCTYPE html>
<html>
<head>
    <title>Remote Control</title>
