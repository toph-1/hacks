                    read -p "Press Enter..."
                else
                    echo -e "${RED}Please configure settings first (Option 6)${NC}"
                    sleep 2
                fi
                ;;
            3)
                create_ip_webcam_instructions
                echo -e "\n${GREEN}✓ IP Webcam instructions created${NC}"
                read -p "Press Enter..."
                ;;
            4)
                create_droidscript_instructions
                echo -e "\n${GREEN}✓ DroidScript code created${NC}"
                read -p "Press Enter..."
                ;;
            5)
                clear
                echo -e "${BLUE}=== FILES ON DESKTOP ===${NC}\n"
                ls -la "$DESKTOP_DIR"/*.py "$DESKTOP_DIR"/*.txt "$DESKTOP_DIR"/*.js 2>/dev/null
                echo ""
                read -p "Press Enter..."
                ;;
            6) configure_settings ;;
            7)
                echo -e "\n${GREEN}Goodbye! Files saved to: $DESKTOP_DIR${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid option${NC}"
                sleep 2
                ;;
        esac
    done
}

