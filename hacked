#!/bin/bash

# =============================================
# ANDROID REMOTE CONTROL - MENU DRIVEN SYSTEM
# Just type numbers, I do the rest!
# =============================================

# Configuration
CONFIG_DIR="$HOME/.android-control"
LISTENER_IP=""
LISTENER_PORT="4444"
LOG_FILE="$CONFIG_DIR/control.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# Create config directory
mkdir -p "$CONFIG_DIR"

# Function to log actions
log_action() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# Function to show header
show_header() {
    clear
    echo -e "${BLUE}"
    echo "╔════════════════════════════════════════════════════════╗"
    echo "║     📱 ANDROID REMOTE CONTROL - MENU DRIVEN v2.0      ║"
    echo "║            Just type numbers, I do the rest!          ║"
    echo "╚════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Function to check/set IP
setup_ip() {
    show_header
    echo -e "${CYAN}=== IP CONFIGURATION ===${NC}\n"
    
    # Get local IP
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    echo -e "Your computer's IP: ${GREEN}$LOCAL_IP${NC}"
    
    if [ -f "$CONFIG_DIR/ip.conf" ]; then
        SAVED_IP=$(cat "$CONFIG_DIR/ip.conf")
        echo -e "Saved IP: ${YELLOW}$SAVED_IP${NC}"
        LISTENER_IP="$SAVED_IP"
    else
        LISTENER_IP="$LOCAL_IP"
    fi
    
    echo ""
    echo "1) Use this IP: $LISTENER_IP"
    echo "2) Enter different IP"
    echo "3) Back to main menu"
    echo ""
    read -p "Choose [1-3]: " ip_choice
    
    case $ip_choice in
        1)
            echo "$LISTENER_IP" > "$CONFIG_DIR/ip.conf"
            echo -e "${GREEN}✓ IP saved: $LISTENER_IP${NC}"
            log_action "IP set to $LISTENER_IP"
            sleep 2
            ;;
        2)
            read -p "Enter IP address: " custom_ip
            if [[ $custom_ip =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
                echo "$custom_ip" > "$CONFIG_DIR/ip.conf"
                LISTENER_IP="$custom_ip"
                echo -e "${GREEN}✓ IP saved: $LISTENER_IP${NC}"
                log_action "IP set to $LISTENER_IP"
            else
                echo -e "${RED}Invalid IP format${NC}"
                sleep 2
            fi
            ;;
    esac
}

# Function to start the listener (Option 1)
start_listener() {
    show_header
    echo -e "${CYAN}=== STARTING LISTENER (OPTION 1) ===${NC}\n"
    
    # Load IP
    if [ -f "$CONFIG_DIR/ip.conf" ]; then
        LISTENER_IP=$(cat "$CONFIG_DIR/ip.conf")
    else
        LISTENER_IP=$(hostname -I | awk '{print $1}')
        echo "$LISTENER_IP" > "$CONFIG_DIR/ip.conf"
    fi
    
    echo -e "Listener will start on: ${GREEN}$LISTENER_IP:$LISTENER_PORT${NC}"
    echo -e "\n${YELLOW}What happens now:${NC}"
    echo "1. Python server starts on port $LISTENER_PORT"
    echo "2. Your Android device can connect to this IP"
    echo "3. You'll see when devices connect"
    echo "4. Commands: stream, stop, shell, get, ls, info, ping, exit"
    echo ""
    read -p "Press Enter to start listener (Ctrl+C to stop)..."

    # Create listener script
    cat > "$CONFIG_DIR/listener.py" << EOF
#!/usr/bin/env python3
import socket
import threading
import cv2
import numpy as np
import struct
import tkinter as tk
from PIL import Image, ImageTk
import queue
import time
import os

SERVER_IP = "0.0.0.0"
SERVER_PORT = $LISTENER_PORT

class VideoViewer:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Android Stream Viewer")
        self.root.geometry("800x600")
        self.canvas = tk.Canvas(self.root, bg='black')
        self.canvas.pack(fill=tk.BOTH, expand=True)
        self.image_queue = queue.Queue()
        self.running = True
        self.update()
        self.root.protocol("WM_DELETE_WINDOW", self.on_close)
    
    def on_close(self):
        self.running = False
        self.root.destroy()
    
    def update(self):
        try:
            while True:
                img = self.image_queue.get_nowait()
                if img is not None:
                    self.display_image(img)
        except queue.Empty:
            pass
        if self.running:
            self.root.after(50, self.update)
    
    def display_image(self, img):
        try:
            canvas_width = self.canvas.winfo_width()
            canvas_height = self.canvas.winfo_height()
            if canvas_width > 1 and canvas_height > 1:
                img_resized = cv2.resize(img, (canvas_width, canvas_height))
                img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)
                img_pil = Image.fromarray(img_rgb)
                img_tk = ImageTk.PhotoImage(img_pil)
                self.canvas.delete("all")
                self.canvas.create_image(canvas_width//2, canvas_height//2, anchor=tk.CENTER, image=img_tk)
                self.canvas.image = img_tk
        except Exception as e:
            print(f"Display error: {e}")
    
    def show_image(self, img):
        if self.running:
            self.image_queue.put(img)
    
    def run(self):
        self.root.mainloop()

class ClientHandler:
    def __init__(self, client_socket, address):
        self.socket = client_socket
        self.address = address
        self.running = True
        self.viewer = None
        self.streaming = False
    
    def handle(self):
        print(f"\n[+] Connected from {self.address}")
        self.send("Welcome to Android Remote Control")
        
        # Start command thread
        cmd_thread = threading.Thread(target=self.command_loop)
        cmd_thread.daemon = True
        cmd_thread.start()
        
        while self.running:
            try:
                if self.streaming:
                    size_data = self.socket.recv(4)
                    if len(size_data) < 4:
                        continue
                    frame_size = struct.unpack('!I', size_data)[0]
                    
                    frame_data = b''
                    remaining = frame_size
                    while remaining > 0:
                        chunk = self.socket.recv(min(4096, remaining))
                        if not chunk:
                            break
                        frame_data += chunk
                        remaining -= len(chunk)
                    
                    if len(frame_data) == frame_size and self.viewer:
                        img = cv2.imdecode(np.frombuffer(frame_data, np.uint8), cv2.IMREAD_COLOR)
                        if img is not None:
                            self.viewer.show_image(img)
                else:
                    self.socket.settimeout(0.5)
                    try:
                        data = self.socket.recv(1024).decode().strip()
                        if data:
                            print(f"\n[Device] {data}")
                    except socket.timeout:
                        pass
            except Exception as e:
                if self.running:
                    print(f"Error: {e}")
                break
        
        self.cleanup()
    
    def command_loop(self):
        while self.running:
            try:
                cmd = input(f"\033[92m{self.address[0]}>\033[0m ")
                if cmd == "stream":
                    self.send("START_STREAM")
                    self.streaming = True
                    self.viewer = VideoViewer()
                    threading.Thread(target=self.viewer.run).start()
                    print("[*] Streaming started")
                elif cmd == "stop":
                    self.send("STOP_STREAM")
                    self.streaming = False
                    if self.viewer:
                        self.viewer.running = False
                    print("[*] Streaming stopped")
                elif cmd == "help":
                    print("Commands: stream, stop, shell <cmd>, get <file>, ls, info, ping, exit")
                elif cmd.startswith("shell "):
                    self.send(f"SHELL:{cmd[6:]}")
                elif cmd.startswith("get "):
                    self.send(f"GET:{cmd[4:]}")
                elif cmd == "ls":
                    self.send("LIST:/sdcard")
                elif cmd == "info":
                    self.send("INFO")
                elif cmd == "ping":
                    self.send("PING")
                elif cmd == "exit":
                    self.send("EXIT")
                    self.running = False
                    break
            except Exception as e:
                print(f"Command error: {e}")
                break
    
    def send(self, msg):
        try:
            self.socket.send((msg + "\n").encode())
        except:
            pass
    
    def cleanup(self):
        self.running = False
        if self.viewer:
            self.viewer.running = False
        try:
            self.socket.close()
        except:
            pass
        print(f"\n[-] Disconnected from {self.address}")

# Start server
server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind((SERVER_IP, SERVER_PORT))
server.listen(5)
server.settimeout(1)

print(f"\n\033[92mListening on port {SERVER_PORT}\033[0m")
print("Waiting for connections... (Ctrl+C to stop)\n")

try:
    while True:
        try:
            client, addr = server.accept()
            handler = ClientHandler(client, addr)
            threading.Thread(target=handler.handle).start()
        except socket.timeout:
            pass
except KeyboardInterrupt:
    print("\n\nServer stopped")
    server.close()
EOF

    chmod +x "$CONFIG_DIR/listener.py"
    python3 "$CONFIG_DIR/listener.py"
}

# Function for ADB wireless setup (Option 2)
setup_adb_wireless() {
    show_header
    echo -e "${CYAN}=== ADB WIRELESS SETUP (OPTION 2) ===${NC}\n"
    
    if ! command -v adb &> /dev/null; then
        echo -e "${YELLOW}Installing ADB...${NC}"
        sudo apt install -y adb
    fi
    
    echo -e "${GREEN}Step 1:${NC} Connect phone via USB"
    echo -e "${GREEN}Step 2:${NC} Enable USB debugging on phone"
    echo ""
    read -p "Press Enter when ready..."
    
    echo -e "\n${YELLOW}Checking connected devices...${NC}"
    adb devices
    
    echo -e "\n${YELLOW}Switching to wireless mode...${NC}"
    adb tcpip 5555
    
    echo -e "\n${GREEN}Step 3:${NC} Disconnect USB cable"
    read -p "Press Enter when USB is disconnected..."
    
    # Load IP
    if [ -f "$CONFIG_DIR/ip.conf" ]; then
        IP=$(cat "$CONFIG_DIR/ip.conf")
    else
        IP=$(hostname -I | awk '{print $1}')
    fi
    
    echo -e "\n${YELLOW}Connecting to $IP:5555...${NC}"
    adb connect $IP:5555
    
    echo -e "\n${GREEN}✓ Wireless connection established!${NC}"
    adb devices
    
    log_action "ADB wireless setup on $IP"
    echo ""
    read -p "Press Enter to continue..."
}

# Function for screen mirroring (Option 3)
start_screen_mirror() {
    show_header
    echo -e "${CYAN}=== SCREEN MIRRORING (OPTION 3) ===${NC}\n"
    
    if ! command -v scrcpy &> /dev/null; then
        echo -e "${YELLOW}Installing scrcpy...${NC}"
        sudo apt install -y scrcpy
    fi
    
    echo "1) Start mirroring (normal)"
    echo "2) Start mirroring (fullscreen)"
    echo "3) Record screen"
    echo "4) Back"
    echo ""
    read -p "Choose [1-4]: " mirror_choice
    
    case $mirror_choice in
        1)
            echo -e "\n${YELLOW}Starting scrcpy...${NC}"
            scrcpy
            ;;
        2)
            echo -e "\n${YELLOW}Starting scrcpy (fullscreen)...${NC}"
            scrcpy -f
            ;;
        3)
            filename="screen_record_$(date +%Y%m%d_%H%M%S).mp4"
            echo -e "\n${YELLOW}Recording to $filename...${NC}"
            echo "Press Ctrl+C to stop recording"
            scrcpy -r "$filename"
            echo -e "${GREEN}✓ Recording saved to $filename${NC}"
            read -p "Press Enter..."
            ;;
    esac
}

# Function for file transfer (Option 4)
file_transfer() {
    show_header
    echo -e "${CYAN}=== FILE TRANSFER (OPTION 4) ===${NC}\n"
    
    echo "1) Push file to phone"
    echo "2) Pull file from phone"
    echo "3) Install APK"
    echo "4) Browse phone files"
    echo "5) Back"
    echo ""
    read -p "Choose [1-5]: " file_choice
    
    case $file_choice in
        1)
            read -p "Local file path: " local_file
            read -p "Remote path [/sdcard/]: " remote_path
            remote_path=${remote_path:-/sdcard/}
            echo -e "\n${YELLOW}Pushing file...${NC}"
            adb push "$local_file" "$remote_path"
            log_action "Pushed $local_file to phone"
            read -p "Press Enter..."
            ;;
        2)
            read -p "Remote file path: " remote_file
            read -p "Local destination [./]: " local_dest
            local_dest=${local_dest:-./}
            echo -e "\n${YELLOW}Pulling file...${NC}"
            adb pull "$remote_file" "$local_dest"
            log_action "Pulled $remote_file from phone"
            read -p "Press Enter..."
            ;;
        3)
            read -p "APK file path: " apk_file
            echo -e "\n${YELLOW}Installing APK...${NC}"
            adb install "$apk_file"
            log_action "Installed APK: $apk_file"
            read -p "Press Enter..."
            ;;
        4)
            echo -e "\n${YELLOW}Opening shell (type 'exit' to quit)...${NC}"
            adb shell
            ;;
    esac
}

