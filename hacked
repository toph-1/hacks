# Function to check dependencies
check_dependencies() {
    echo -e "${BLUE}[*] Checking dependencies...${NC}"
    
    # Check for nmap
    if ! command -v nmap &> /dev/null; then
        echo -e "${RED}[!] nmap not found. Some features may be limited${NC}"
        echo -e "${YELLOW}Install with: sudo apt-get install nmap (Linux) or brew install nmap (Mac)${NC}"
    else
        echo -e "${GREEN}[✓] nmap found${NC}"
    fi
    
    # Check for netcat
    if ! command -v nc &> /dev/null; then
        echo -e "${YELLOW}[!] netcat not found. Some features may be limited${NC}"
    else
        echo -e "${GREEN}[✓] netcat found${NC}"
    fi
    
    # Check for hping3
    if ! command -v hping3 &> /dev/null; then
        echo -e "${YELLOW}[!] hping3 not found (SYN scan will be limited)${NC}"
    else
        echo -e "${GREEN}[✓] hping3 found${NC}"
    fi
    
    echo ""
}

# Function to validate IP address
validate_ip() {
    local ip=$1
    if [[ $ip =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        # Check each octet is between 0-255
        IFS='.' read -r -a octets <<< "$ip"
        for octet in "${octets[@]}"; do
            if ((octet < 0 || octet > 255)); then
                return 1
            fi
        done
        return 0
    else
        return 1
    fi
}

# FIXED: Function for TCP Connect scan
tcp_connect_scan() {
    echo -e "\n${CYAN}[*] Starting TCP Connect Scan on $TARGET${NC}"
    echo -e "${CYAN}[*] Scanning ports $START_PORT to $END_PORT${NC}\n"
    
    local open_ports=()
    local total_ports=$((END_PORT - START_PORT + 1))
    local current=0
    
    for ((port=$START_PORT; port<=$END_PORT; port++)); do
        # Progress indicator
        current=$((current + 1))
        percentage=$((current * 100 / total_ports))
        echo -ne "${YELLOW}[*] Progress: $current/$total_ports ($percentage%) - Testing port $port...${NC}\r"
        
        # TCP connection attempt using /dev/tcp (bash built-in)
        (echo >/dev/tcp/$TARGET/$port) 2>/dev/null &
        local pid=$!
        
        # Wait with timeout
        sleep $TIMEOUT
        if kill -0 $pid 2>/dev/null; then
            kill $pid 2>/dev/null
            wait $pid 2>/dev/null
        else
            wait $pid 2>/dev/null
            if [ $? -eq 0 ]; then
                echo -e "\n${GREEN}[+] Port $port is OPEN${NC}"
                open_ports+=($port)
            fi
        fi
    done
    
    echo -e "\n\n${GREEN}[✓] Scan Complete!${NC}"
    if [ ${#open_ports[@]} -eq 0 ]; then
        echo -e "${YELLOW}[!] No open ports found${NC}"
    else
        echo -e "${GREEN}[+] Open ports: ${open_ports[*]}${NC}"
        
        # Try to identify services on open ports
        echo -e "\n${BLUE}[*] Attempting service identification...${NC}"
        for port in "${open_ports[@]}"; do
            service=$(grep -w "^$port/" /etc/services 2>/dev/null | head -1 | awk '{print $1}')
            if [ -n "$service" ]; then
                echo -e "${GREEN}[+] Port $port: $service${NC}"
            else
                echo -e "${YELLOW}[?] Port $port: Unknown service${NC}"
            fi
        done
    fi
}

# FIXED: Function for SYN scan
syn_scan() {
    echo -e "\n${CYAN}[*] Starting SYN Stealth Scan on $TARGET${NC}"
    echo -e "${CYAN}[*] This scan is less likely to be logged${NC}\n"
    
    if command -v hping3 &> /dev/null; then
        echo -e "${BLUE}[*] Using hping3 for SYN scan...${NC}\n"
        sudo hping3 -S -p $START_PORT-$END_PORT --scan known $TARGET 2>/dev/null
    elif command -v nmap &> /dev/null; then
        echo -e "${BLUE}[*] Using nmap for SYN scan...${NC}\n"
        sudo nmap -sS -p $START_PORT-$END_PORT $TARGET
    else
        echo -e "${RED}[!] Neither hping3 nor nmap found for SYN scan.${NC}"
        echo -e "${YELLOW}[*] Falling back to TCP Connect scan...${NC}\n"
        tcp_connect_scan
    fi
}

# FIXED: Function for UDP scan
udp_scan() {
    echo -e "\n${CYAN}[*] Starting UDP Scan on $TARGET${NC}"
    echo -e "${YELLOW}[!] UDP scans can be slow and unreliable${NC}\n"
    
    if command -v nmap &> /dev/null; then
        echo -e "${BLUE}[*] Using nmap for UDP scan (this may take a while)...${NC}\n"
        sudo nmap -sU -p $START_PORT-$END_PORT $TARGET
    else
        echo -e "${RED}[!] nmap is required for UDP scans.${NC}"
        echo -e "${YELLOW}[*] Please install nmap: sudo apt-get install nmap${NC}"
    fi
}

# FIXED: Function for aggressive scan with nmap
nmap_aggressive() {
    echo -e "\n${CYAN}[*] Starting Nmap Aggressive Scan${NC}"
    echo -e "${YELLOW}[!] This scan is very noisy and will be detected${NC}\n"
    
    if command -v nmap &> /dev/null; then
        nmap -A -T4 $TARGET -p $START_PORT-$END_PORT
    else
        echo -e "${RED}[!] nmap is required for aggressive scans.${NC}"
    fi
}

# FIXED: Function for bypass techniques scan
bypass_scan() {
